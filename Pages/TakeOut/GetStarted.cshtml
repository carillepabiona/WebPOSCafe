@page
@model WebPOSCafe.Pages.TakeOut.GetStartedModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Get Started | Dine In</title>

    <style>
            :root {
                --white: #ffffff;
                --soft-white: #fafafa;
                --orange: #ff8c00;
                --orange-dark: #e67600;
                --text-dark: #2b2b2b;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: Arial, Helvetica, sans-serif;
            }

            body, html {
                height: 100%;
                width: 100%;
                background: var(--soft-white);
                overflow: hidden;
            }

            .landing-page {
                position: relative;
                width: 100%;
                height: 100vh;
            }

            /* BACKGROUND IMAGE */
            .background-image {
                position: absolute;
                width: 100%;
                height: 100%;
                object-fit: cover;
                z-index: 1;
                filter: brightness(0.75) contrast(1.05);
            }

            /* OVERLAY */
            .overlay {
                position: absolute;
                width: 100%;
                height: 100%;
                background: linear-gradient( to bottom, rgba(255, 140, 0, 0.25), rgba(255, 255, 255, 0.85) );
                z-index: 2;
            }

            /* HERO CONTENT */
            .hero-section {
                position: relative;
                z-index: 3;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                text-align: center;
                padding: 20px;
            }

            .hero-title {
                font-size: 2.2rem;
                font-weight: bold;
                color: var(--white);
                margin-bottom: 10px;
                text-shadow: 0 4px 12px rgba(0,0,0,0.4);
            }

            .hero-subtitle {
                font-size: 1rem;
                color: rgba(255,255,255,0.9);
                margin-bottom: 30px;
                text-shadow: 0 2px 8px rgba(0,0,0,0.3);
            }

            /* BUTTON */
            .get-started-btn {
                background: var(--orange);
                color: var(--white);
                padding: 14px 34px;
                border-radius: 30px;
                font-size: 1rem;
                font-weight: 600;
                text-decoration: none;
                transition: 0.25s ease;
                box-shadow: 0 10px 25px rgba(255, 140, 0, 0.35);
            }

                .get-started-btn:hover {
                    background: var(--orange-dark);
                    transform: translateY(-2px);
                }

                .get-started-btn:active {
                    transform: scale(0.96);
                }

            /* MOBILE RESPONSIVE */
            @@media (max-width: 600px) {
                .hero-title {
                    font-size: 1.8rem;
                }

                .hero-subtitle {
                    font-size: 0.9rem;
                }

                .get-started-btn {
                    width: 80%;
                    text-align: center;
                }
            }
    </style>
</head>

<body>

    <div class="landing-page">

        <!-- FULL BACKGROUND -->
        <img src="images/bg.png"
             alt="Cafe Background"
             class="background-image" />

        <!-- OVERLAY -->
        <div class="overlay"></div>

        <!-- CONTENT -->
        <section class="hero-section">

            <div class="hero-title">Welcome to Verso Cafe</div>
            <div class="hero-subtitle">Fresh coffee. Fast ordering. Dine in with ease.</div>

            <!-- GET STARTED BUTTON -->
            <a href="/Menu/MenuDisplay" class="get-started-btn">
                Get Started
            </a>

        </section>

    </div>

</body>
</html>