@page
@model WebPOSCafe.Pages.TakeOut.TakeOutMenuModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verso Cafe — Kiosk</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/kiosk.css" />
    <style>
        /* ── paste your full existing <style> block here unchanged ── */
        :root {
        --brand: #e47835;
        --brand-dark: #c8631f;
        --brand-soft: #fdeee2;
        --brand-softer: #fff7f0;
        --ink: #1c1917;
        --ink-2: #44403c;
        --muted: #78716c;
        --line: #f0ece8;
        --bg: #ffffff;
        --shadow-sm: 0 1px 2px rgba(28,25,23,.05);
        --shadow: 0 8px 24px -8px rgba(228,120,53,.18),0 2px 6px rgba(28,25,23,.04);
        --shadow-lg: 0 30px 60px -20px rgba(28,25,23,.18);
        --radius: 20px;
        --radius-sm: 14px;
        }

        * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        -webkit-tap-highlight-color: transparent
        }

        html, body {
        height: 100%
        }

        body {
        font-family: 'Plus Jakarta Sans',system-ui,-apple-system,sans-serif;
        background: var(--bg);
        color: var(--ink);
        overflow: hidden;
        user-select: none;
        }

        button {
        font-family: inherit;
        cursor: pointer;
        border: none;
        background: none;
        color: inherit
        }

        .app {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column
        }

        .screen {
        position: absolute;
        inset: 0;
        opacity: 0;
        pointer-events: none;
        transition: opacity .35s ease,transform .35s ease;
        transform: translateY(8px);
        overflow: hidden
        }

        .screen.active {
        opacity: 1;
        pointer-events: auto;
        transform: none
        }

        #welcome {
        background: radial-gradient(1200px 600px at 80% -10%,var(--brand-soft),transparent 60%),radial-gradient(900px 500px at -10% 110%,#fff3e8,transparent 60%),#fff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px;
        }

        .brand-mark {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px
        }

        .brand-mark .logo {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        background: var(--brand);
        display: grid;
        place-items: center;
        color: #fff;
        font-size: 30px;
        box-shadow: var(--shadow)
        }

        .brand-mark h2 {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: .3em;
        color: var(--ink-2)
        }

        .hero-title {
        font-size: clamp(64px,9vw,140px);
        font-weight: 800;
        letter-spacing: -.04em;
        line-height: 1;
        background: linear-gradient(135deg,var(--ink) 0%,var(--brand) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent
        }

        .hero-sub {
        margin-top: 18px;
        color: var(--muted);
        font-size: 20px;
        max-width: 520px
        }

        .tiles {
        display: flex;
        flex-direction: column;
        gap: 24px;
        margin-top: 60px;
        width: min(820px,95%);
        justify-content: center;
        align-items: center;
        }

        .tile {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 28px;
        padding: 40px 32px;
        text-align: left;
        transition: .25s;
        box-shadow: var(--shadow-sm);
        justify-content: center;
        align-items: center;
        text-align: center
        }

        .tile:hover, .tile:active {
        transform: translateY(-4px);
        border-color: var(--brand);
        box-shadow: var(--shadow-lg)
        }

        .tile .icon {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        background: var(--brand-soft);
        color: var(--brand);
        display: grid;
        place-items: center;
        font-size: 32px;
        margin-bottom: 24px;
        justify-content: center;
        align-items: center;
        text-align: center;
        }

        .tile h3 {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -.01em
        }

        .tile p {
        color: var(--muted);
        margin-top: 6px;
        font-size: 16px
        }

        .tile .arrow {
        margin-top: 28px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--brand);
        font-weight: 600
        }

        .tap-hint {
        position: absolute;
        bottom: 32px;
        color: var(--muted);
        font-size: 14px;
        letter-spacing: .2em;
        text-transform: uppercase
        }

        #menu {
        display: flex;
        flex-direction: column;
        background: #fff
        }

        .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 28px;
        border-bottom: 1px solid var(--line);
        background: #fff;
        z-index: 5
        }

        .topbar .left {
        display: flex;
        align-items: center;
        gap: 14px
        }

        .topbar .logo {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: var(--brand);
        color: #fff;
        display: grid;
        place-items: center;
        font-size: 18px
        }

        .topbar .name {
        font-weight: 800;
        letter-spacing: .04em;
        font-size: 18px
        }

        .order-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--brand-soft);
        color: var(--brand-dark);
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 13px
        }

        .topbar .right {
        display: flex;
        align-items: center;
        gap: 18px;
        color: var(--muted);
        font-size: 14px
        }

        .topbar .startover {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 12px;
        border: 1px solid var(--line);
        font-weight: 600;
        color: var(--ink-2);
        font-size: 14px
        }

        .topbar .startover:hover {
        border-color: var(--brand);
        color: var(--brand)
        }

        .menu-body {
        flex: 1;
        display: grid;
        grid-template-columns: 220px 1fr;
        min-height: 0
        }

        .cats {
        padding: 22px 14px;
        border-right: 1px solid var(--line);
        overflow-y: auto
        }

        .cat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 14px;
        border-radius: 14px;
        color: var(--ink-2);
        font-weight: 600;
        font-size: 15px;
        width: 100%;
        text-align: left;
        margin-bottom: 6px;
        transition: .2s
        }

        .cat i {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        background: var(--brand-softer);
        color: var(--brand);
        display: grid;
        place-items: center;
        font-size: 14px
        }

        .cat:hover {
        background: #faf7f4
        }

        .cat.active {
        background: var(--brand);
        color: #fff
        }

        .cat.active i {
        background: rgba(255,255,255,.18);
        color: #fff
        }

        .items-wrap {
        overflow-y: auto;
        padding: 28px 32px 140px
        }

        .items-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        margin-bottom: 22px
        }

        .items-head h1 {
        font-size: 34px;
        font-weight: 800;
        letter-spacing: -.02em
        }

        .items-head p {
        color: var(--muted);
        margin-top: 4px
        }

        .search {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #faf7f4;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 12px 16px;
        width: 300px
        }

        .search input {
        border: none;
        outline: none;
        background: transparent;
        width: 100%;
        font: inherit;
        color: var(--ink)
        }

        .search i {
        color: var(--muted)
        }

        .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(240px,1fr));
        gap: 20px
        }

        .card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 18px;
        display: flex;
        flex-direction: column;
        transition: .2s;
        cursor: pointer;
        position: relative;
        overflow: hidden
        }

        .card:hover {
        transform: translateY(-4px);
        border-color: var(--brand);
        box-shadow: var(--shadow)
        }

        .card .thumb {
        height: 130px;
        border-radius: var(--radius-sm);
        background: linear-gradient(135deg,var(--brand-softer),var(--brand-soft));
        display: grid;
        place-items: center;
        font-size: 54px;
        color: var(--brand);
        margin-bottom: 14px;
        overflow: hidden
        }

        .card .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: var(--radius-sm)
        }

        .card h4 {
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -.01em
        }

        .card .desc {
        color: var(--muted);
        font-size: 13px;
        margin-top: 4px;
        line-height: 1.45;
        flex: 1
        }

        .card .row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 14px
        }

        .card .price {
        font-weight: 800;
        font-size: 18px
        }

        .card .add {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: var(--brand);
        color: #fff;
        display: grid;
        place-items: center;
        font-size: 16px;
        transition: .2s
        }

        .card .add:hover {
        background: var(--brand-dark);
        transform: scale(1.05)
        }

        .cart-fab {
        position: absolute;
        bottom: 24px;
        right: 24px;
        background: var(--brand);
        color: #fff;
        padding: 16px 22px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        font-weight: 700;
        box-shadow: 0 18px 40px -10px rgba(228,120,53,.55);
        transition: .2s;
        z-index: 10
        }

        .cart-fab:hover {
        background: var(--brand-dark);
        transform: translateY(-2px)
        }

        .cart-fab .badge {
        background: rgba(255,255,255,.22);
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px
        }

        .cart-fab.hidden {
        transform: translateY(120%);
        opacity: 0;
        pointer-events: none
        }

        .cart-fab.bump {
        animation: bump .4s ease
        }

        @@keyframes bump {
        0% {
        transform: scale(1)
        }

        40% {
        transform: scale(1.08)
        }

        100% {
        transform: scale(1)
        }
        }

        .modal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(28,25,23,.45);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: .25s;
        z-index: 50
        }

        .modal-overlay.show {
        opacity: 1;
        pointer-events: auto
        }

        .modal {
        background: #fff;
        border-radius: 28px;
        width: min(560px,92%);
        max-height: 88vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transform: translateY(20px);
        transition: .3s;
        box-shadow: var(--shadow-lg)
        }

        .modal-overlay.show .modal {
        transform: none
        }

        .modal-head {
        position: relative;
        height: 180px;
        background: linear-gradient(135deg,var(--brand-soft),var(--brand-softer));
        display: grid;
        place-items: center;
        font-size: 84px;
        color: var(--brand);
        overflow: hidden
        }

        .modal-head img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        inset: 0
        }

        .modal-head .modal-close {
        z-index: 2
        }

        .modal-close {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgba(255,255,255,.85);
        color: var(--ink);
        display: grid;
        place-items: center
        }

        .modal-body {
        padding: 24px 28px;
        overflow-y: auto;
        flex: 1
        }

        .modal-body h3 {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -.02em
        }

        .modal-body .m-desc {
        color: var(--muted);
        margin-top: 6px;
        font-size: 14px
        }

        .opt-group {
        margin-top: 22px
        }

        .opt-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px
        }

        .seg {
        display: flex;
        background: #faf7f4;
        border-radius: 14px;
        padding: 4px;
        border: 1px solid var(--line)
        }

        .seg button {
        flex: 1;
        padding: 12px;
        border-radius: 11px;
        font-weight: 600;
        color: var(--ink-2);
        font-size: 14px;
        transition: .2s
        }

        .seg button.on {
        background: var(--brand);
        color: #fff;
        box-shadow: 0 4px 12px -4px rgba(228,120,53,.5)
        }

        .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px
        }

        .chip {
        padding: 10px 16px;
        border-radius: 999px;
        border: 1.5px solid var(--line);
        font-weight: 600;
        color: var(--ink-2);
        font-size: 14px;
        transition: .15s
        }

        .chip.on {
        border-color: var(--brand);
        background: var(--brand-soft);
        color: var(--brand-dark)
        }

        .modal-foot {
        padding: 18px 28px;
        border-top: 1px solid var(--line);
        display: flex;
        align-items: center;
        gap: 14px
        }

        .stepper {
        display: flex;
        align-items: center;
        background: #faf7f4;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 4px
        }

        .stepper button {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        color: var(--brand);
        font-size: 14px
        }

        .stepper button:hover {
        background: #fff
        }

        .stepper .qty {
        width: 36px;
        text-align: center;
        font-weight: 700
        }

        .add-btn {
        flex: 1;
        background: var(--brand);
        color: #fff;
        padding: 16px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: .2s
        }

        .add-btn:hover {
        background: var(--brand-dark)
        }

        #cart {
        background: #fff;
        display: flex;
        flex-direction: column
        }

        .cart-body {
        flex: 1;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        min-height: 0
        }

        .cart-list {
        overflow-y: auto;
        padding: 28px 32px;
        border-right: 1px solid var(--line)
        }

        .cart-list h1 {
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -.02em;
        margin-bottom: 6px
        }

        .cart-list .sub {
        color: var(--muted);
        margin-bottom: 22px
        }

        .line {
        display: grid;
        grid-template-columns: 64px 1fr auto;
        gap: 16px;
        padding: 18px 0;
        border-bottom: 1px solid var(--line);
        align-items: center
        }

        .line .ico {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        background: var(--brand-softer);
        color: var(--brand);
        display: grid;
        place-items: center;
        font-size: 26px;
        overflow: hidden
        }

        .line .ico img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 14px
        }

        .line h5 {
        font-weight: 700;
        font-size: 16px
        }

        .line .mods {
        color: var(--muted);
        font-size: 13px;
        margin-top: 4px
        }

        .line .price {
        font-weight: 800;
        font-size: 16px;
        text-align: right
        }

        .line .remove {
        margin-top: 6px;
        color: var(--muted);
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        gap: 6px
        }

        .line .remove:hover {
        color: var(--brand)
        }

        .cart-empty {
        text-align: center;
        color: var(--muted);
        padding: 80px 20px
        }

        .cart-empty i {
        font-size: 60px;
        color: var(--brand);
        margin-bottom: 14px;
        opacity: .5
        }

        .checkout {
        padding: 28px;
        display: flex;
        flex-direction: column;
        background: #fafaf9
        }

        .summary {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 22px;
        margin-bottom: 18px
        }

        .summary h4 {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px
        }

        .srow {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        font-size: 15px;
        color: var(--ink-2)
        }

        .srow.total {
        border-top: 1px dashed var(--line);
        margin-top: 10px;
        padding-top: 14px;
        font-weight: 800;
        font-size: 22px;
        color: var(--ink)
        }

        .pay h4 {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 12px
        }

        .pay-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px
        }

        .pay-opt {
        background: #fff;
        border: 1.5px solid var(--line);
        border-radius: 14px;
        padding: 18px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
        transition: .15s
        }

        .pay-opt i {
        font-size: 22px;
        color: var(--brand)
        }

        .pay-opt span {
        font-weight: 600;
        font-size: 14px
        }

        .pay-opt.on {
        border-color: var(--brand);
        background: var(--brand-softer)
        }

        .place {
        margin-top: auto;
        background: var(--brand);
        color: #fff;
        padding: 18px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: .2s
        }

        .place:hover {
        background: var(--brand-dark)
        }

        .place:disabled {
        opacity: .5;
        cursor: not-allowed
        }

        .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--ink-2);
        font-weight: 600;
        font-size: 14px;
        padding: 10px 14px;
        border-radius: 12px;
        border: 1px solid var(--line);
        margin-bottom: 18px
        }

        .back-btn:hover {
        border-color: var(--brand);
        color: var(--brand)
        }

        #confirm {
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px
        }

        .confirm-card {
        max-width: 480px
        }

        .check {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: var(--brand-soft);
        color: var(--brand);
        display: grid;
        place-items: center;
        font-size: 56px;
        margin: 0 auto 24px;
        animation: pop .5s ease
        }

        @@keyframes pop {
        0% {
        transform: scale(.5);
        opacity: 0
        }

        100% {
        transform: scale(1);
        opacity: 1
        }
        }

        #confirm h1 {
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -.02em
        }

        #confirm p {
        color: var(--muted);
        margin-top: 8px;
        font-size: 16px
        }

        .order-no {
        margin-top: 28px;
        padding: 24px;
        border: 1.5px dashed var(--brand);
        border-radius: 20px;
        background: var(--brand-softer)
        }

        .order-no .lbl {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted)
        }

        .order-no .num {
        font-size: 48px;
        font-weight: 800;
        color: var(--brand);
        letter-spacing: .05em;
        margin-top: 4px
        }

        .eta {
        margin-top: 18px;
        color: var(--ink-2);
        font-size: 15px
        }

        .new-order {
        margin-top: 28px;
        background: var(--brand);
        color: #fff;
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px
        }

        .new-order:hover {
        background: var(--brand-dark)
        }
    </style>
</head>
<body>
    <div class="app">

        <!-- WELCOME -->
        <section class="screen active" id="welcome">
            <div class="brand-mark">
                <div class="logo"><i class="fa-solid fa-mug-saucer"></i></div>
                <h2>VERSO</h2>
            </div>
            <div class="hero-title">Verso Cafe</div>
            <p class="hero-sub">Hand-crafted coffee, fresh pastries, and good mornings — order in seconds.</p>
            <div class="tiles">
                <button class="tile" data-type="Takeaway">
                    <div class="icon"><i class="fa-solid fa-bag-shopping"></i></div>
                    <h3>Takeaway</h3>
                    <p>Grab your order and go</p>
                    <span class="arrow">Start order <i class="fa-solid fa-arrow-right"></i></span>
                </button>
            </div>
            <div class="tap-hint">Tap to begin</div>
        </section>

        <!-- MENU -->
        <section class="screen" id="menu">
            <div class="topbar">
                <div class="left">
                    <div class="logo"><i class="fa-solid fa-mug-saucer"></i></div>
                    <div class="name">VERSO CAFE</div>
                    <span class="order-pill"><i class="fa-solid fa-circle" style="font-size:6px"></i> <span id="orderType">Takeaway</span></span>
                </div>
                <div class="right">
                    <span id="clock"></span>
                    <button class="startover" onclick="resetAll()"><i class="fa-solid fa-rotate-left"></i> Start Over</button>
                </div>
            </div>
            <div class="menu-body">
                <aside class="cats" id="cats"></aside>
                <div class="items-wrap">
                    <div class="items-head">
                        <div>
                            <h1 id="catTitle">Menu</h1>
                            <p id="catSub">Select a category</p>
                        </div>
                        <div class="search">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input id="search" placeholder="Search the menu..." />
                        </div>
                    </div>
                    <div class="grid" id="grid"></div>
                </div>
            </div>
            <button class="cart-fab hidden" id="cartFab" onclick="showScreen('cart');renderCart()">
                <i class="fa-solid fa-basket-shopping"></i>
                <span><span id="fabCount">0</span> items</span>
                <span class="badge">₱<span id="fabTotal">0.00</span></span>
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </section>

        <!-- CART -->
        <section class="screen" id="cart">
            <div class="topbar">
                <div class="left">
                    <div class="logo"><i class="fa-solid fa-mug-saucer"></i></div>
                    <div class="name">VERSO CAFE</div>
                    <span class="order-pill"><i class="fa-solid fa-circle" style="font-size:6px"></i> <span class="orderTypeEcho">Takeaway</span></span>
                </div>
                <div class="right">
                    <button class="startover" onclick="resetAll()"><i class="fa-solid fa-rotate-left"></i> Start Over</button>
                </div>
            </div>
            <div class="cart-body">
                <div class="cart-list">
                    <button class="back-btn" onclick="showScreen('menu')"><i class="fa-solid fa-arrow-left"></i> Back to menu</button>
                    <h1>Your Order</h1>
                    <p class="sub">Review items before checkout</p>
                    <div id="lines"></div>
                </div>
                <div class="checkout">
                    <div class="summary">
                        <h4>Order Summary</h4>
                        <div class="srow"><span>Subtotal</span><span>₱<span id="sub">0.00</span></span></div>
                        <div class="srow"><span>Tax (12%)</span><span>₱<span id="tax">0.00</span></span></div>
                        <div class="srow total"><span>Total</span><span>₱<span id="tot">0.00</span></span></div>
                    </div>
                    <div class="pay">
                        <h4>Payment Method</h4>
                        <div class="pay-grid" id="payGrid">
                            <button class="pay-opt on" data-pay="cash">
                                <i class="fa-solid fa-money-bill-wave"></i>
                                <span>Cash at counter</span>
                            </button>
                        </div>
                    </div>
                    <button class="place" id="place" onclick="placeOrder()">
                        <i class="fa-solid fa-lock"></i> Place Order
                    </button>
                </div>
            </div>
        </section>

        <!-- CONFIRMATION -->
        <!-- CONFIRMATION MODAL — overlays on top of cart screen -->
        <div class="modal-overlay" id="confirm-overlay">
            <div class="modal" style="width:min(480px,94%);max-height:92vh;border-radius:28px;overflow:hidden;display:flex;flex-direction:column;">

                <!-- Header -->
                <div style="background:var(--brand);padding:32px 24px 24px;text-align:center;flex-shrink:0;">
                    <div style="width:72px;height:72px;background:rgba(255,255,255,0.2);border-radius:50%;
                        display:flex;align-items:center;justify-content:center;margin:0 auto 14px;
                        font-size:36px;animation:pop .5s ease;">
                        <i class="fa-solid fa-check" style="color:#fff;"></i>
                    </div>
                    <div style="color:#fff;font-size:22px;font-weight:800;letter-spacing:-.02em;">Order Confirmed!</div>
                    <div style="color:rgba(255,255,255,0.8);font-size:13px;margin-top:4px;">
                        Verso Cafe &mdash; <span id="conf-type">Takeaway</span>
                    </div>
                </div>

                <!-- Order number -->
                <div style="text-align:center;padding:22px 24px 0;flex-shrink:0;">
                    <div style="font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
                        color:var(--muted);margin-bottom:6px;">
                        Your Order Number
                    </div>
                    <div id="conf-num" style="font-size:80px;font-weight:800;color:var(--brand);
                        letter-spacing:.04em;line-height:1;">
                        —
                    </div>
                    <div style="font-size:12px;color:var(--muted);margin-top:6px;">
                        Staff will call your number when ready
                    </div>
                </div>

                <!-- Dashed divider -->
                <div style="display:flex;align-items:center;gap:8px;padding:16px 24px;flex-shrink:0;">
                    <div style="flex:1;border-top:2px dashed #e8e0d8;"></div>
                    <i class="fa-solid fa-scissors" style="color:#c5b9ad;font-size:13px;"></i>
                    <div style="flex:1;border-top:2px dashed #e8e0d8;"></div>
                </div>

                <!-- Scrollable order summary -->
                <div style="overflow-y:auto;padding:0 24px;flex:1;">
                    <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
                        color:var(--muted);margin-bottom:12px;">
                        Order Summary
                    </div>

                    <div id="conf-items"></div>

                    <!-- Totals -->
                    <div style="padding:12px 0 4px;border-top:1px dashed #e8e0d8;margin-top:4px;">
                        <div style="display:flex;justify-content:space-between;font-size:13px;
                            color:var(--muted);padding:3px 0;">
                            <span>Subtotal</span><span>₱<span id="conf-sub">0.00</span></span>
                        </div>
                        <div style="display:flex;justify-content:space-between;font-size:13px;
                            color:var(--muted);padding:3px 0;">
                            <span>Tax (12%)</span><span>₱<span id="conf-tax">0.00</span></span>
                        </div>
                        <div style="display:flex;justify-content:space-between;font-size:17px;
                            font-weight:800;padding:10px 0 0;">
                            <span>Total</span>
                            <span style="color:var(--brand);">₱<span id="conf-total">0.00</span></span>
                        </div>
                    </div>
                </div>

                <!-- ETA banner -->
                <div style="margin:16px 24px 0;background:var(--brand-softer);border-radius:14px;
                    padding:14px 16px;display:flex;align-items:center;gap:12px;flex-shrink:0;">
                    <i class="fa-regular fa-clock" style="color:var(--brand);font-size:20px;flex-shrink:0;"></i>
                    <div>
                        <div style="font-size:13px;font-weight:700;color:var(--brand-dark);">
                            Ready in <span id="conf-eta">5–10</span> minutes
                        </div>
                        <div style="font-size:12px;color:var(--muted);">Pay cash at the counter when called</div>
                    </div>
                </div>

                <!-- New order button -->
                <div style="padding:16px 24px 24px;flex-shrink:0;">
                    <button onclick="resetAll()"
                            style="width:100%;background:var(--brand);color:#fff;padding:16px;
                        border-radius:14px;font-weight:700;font-size:15px;
                        display:flex;align-items:center;justify-content:center;gap:10px;
                        transition:.2s;border:none;cursor:pointer;"
                            onmouseover="this.style.background='var(--brand-dark)'"
                            onmouseout="this.style.background='var(--brand)'">
                        <i class="fa-solid fa-rotate-left"></i> Start a New Order
                    </button>
                </div>

            </div>
        </div>

        <!-- MODAL — built dynamically per item -->
        <div class="modal-overlay" id="modal">
            <div class="modal">
                <div class="modal-head" id="modalHead">
                    <button class="modal-close" onclick="closeModal()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                    <i id="mIcon" class="fa-solid fa-mug-hot"></i>
                </div>
                <div class="modal-body">
                    <h3 id="mName"></h3>
                    <p class="m-desc" id="mDesc"></p>
                    <div id="mCustomizations"></div>
                    <div id="mAddons"></div>
                </div>
                <div class="modal-foot">
                    <div class="stepper">
                        <button onclick="changeQty(-1)"><i class="fa-solid fa-minus"></i></button>
                        <span class="qty" id="qty">1</span>
                        <button onclick="changeQty(1)"><i class="fa-solid fa-plus"></i></button>
                    </div>
                    <button class="add-btn" onclick="addToCart()">
                        <span>Add to Order</span>
                        <span>₱<span id="mPrice">0.00</span></span>
                    </button>
                </div>
            </div>
        </div>

    </div>

    <script>
        // ── DB data injected by Razor ──────────────────────────────────────────────
        const categories = @Html.Raw(Model.CategoriesJson);
        const items      = @Html.Raw(Model.ItemsJson);

        // ── State ──────────────────────────────────────────────────────────────────
        let currentCat   = categories.length ? categories[0].id : null;
        let cart         = [];
        let editing      = null;   // full item object being customized
        let modalSelections = {};  // { customizationId: [optionId, ...] }
        let modalAddons     = {};  // { addonId: true }
        let modalQty        = 1;
        let payment         = 'cash';

        // ── Helpers ────────────────────────────────────────────────────────────────
        const $  = (s, p = document) => p.querySelector(s);
        const $$ = (s, p = document) => [...p.querySelectorAll(s)];
        const money = n => Number(n).toFixed(2);

        function showScreen(id) {
        $$('.screen').forEach(s => s.classList.toggle('active', s.id === id));
        }

        // ── Welcome ────────────────────────────────────────────────────────────────
        $$('#welcome .tile').forEach(t => t.addEventListener('click', () => {
        $('#orderType').textContent = t.dataset.type;
        $$('.orderTypeEcho').forEach(el => el.textContent = t.dataset.type);
        showScreen('menu');
        }));

        // ── Clock ──────────────────────────────────────────────────────────────────
        function tickClock() {
        const d = new Date();
        $('#clock').innerHTML = '<i class="fa-regular fa-clock"></i> '
        + d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }
        tickClock();
        setInterval(tickClock, 30000);

        // ── Categories ─────────────────────────────────────────────────────────────
        function renderCats() {
        $('#cats').innerHTML = categories.map(c => `
        <button class="cat ${c.id === currentCat ? 'active' : ''}" data-id="${c.id}">
        <i class="fa-solid fa-tag"></i> ${c.name}
        </button>`).join('');

        $$('#cats .cat').forEach(b => b.addEventListener('click', () => {
        currentCat = b.dataset.id;
        const cat  = categories.find(x => x.id === currentCat);
        $('#catTitle').textContent = cat.name;
        $('#catSub').textContent   = cat.sub || '';
        $('#search').value = '';
        renderCats();
        renderGrid();
        }));
        }

        // ── Grid ───────────────────────────────────────────────────────────────────
        function renderGrid(filter = '') {
        const q    = filter.trim().toLowerCase();
        const list = items.filter(i =>
        q ? (i.name + (i.desc || '')).toLowerCase().includes(q)
        : i.cat === currentCat
        );

        $('#grid').innerHTML = list.length
        ? list.map(i => `
        <div class="card" data-id="${i.id}">
        <div class="thumb">
        ${i.image
        ? `<img src="${i.image}" alt="${i.name}" />`
        : `<i class="fa-solid fa-mug-hot"></i>`}
        </div>
        <h4>${i.name}</h4>
        <p class="desc">${i.desc || ''}</p>
        <div class="row">
        <span class="price">₱${money(i.price)}</span>
        <button class="add"><i class="fa-solid fa-plus"></i></button>
        </div>
        </div>`).join('')
        : `<p style="color:var(--muted);padding:40px 0;">No items found.</p>`;

        $$('#grid .card').forEach(c =>
        c.addEventListener('click', () => openModal(c.dataset.id)));
        }

        $('#search').addEventListener('input', e => renderGrid(e.target.value));

        // ── Modal ──────────────────────────────────────────────────────────────────
        function openModal(id) {
        const it = items.find(i => i.id == id);
        if (!it) return;
        editing          = it;
        modalSelections  = {};
        modalAddons      = {};
        modalQty         = 1;

        // Header image or icon
        const head = $('#modalHead');
        head.querySelectorAll('img').forEach(el => el.remove());
        $('#mIcon').style.display = '';
        if (it.image) {
        const img = document.createElement('img');
        img.src = it.image;
        img.alt = it.name;
        head.appendChild(img);
        $('#mIcon').style.display = 'none';
        }

        $('#mName').textContent = it.name;
        $('#mDesc').textContent = it.desc || '';
        $('#qty').textContent   = 1;

        // ── Render customizations from DB ──────────────────────────────────────
        const custEl = $('#mCustomizations');
        custEl.innerHTML = '';
        (it.customizations || []).forEach(c => {
        // Set defaults
        modalSelections[c.id] = c.options
        .filter(o => o.isDefault)
        .map(o => o.id);
        if (c.type === 'Radio' && modalSelections[c.id].length === 0 && c.options.length)
        modalSelections[c.id] = [c.options[0].id];

        const group = document.createElement('div');
        group.className = 'opt-group';
        group.innerHTML = `
        <div class="opt-label">
        ${c.name}${c.required ? ' <span style="color:var(--brand)">*</span>' : ''}
        </div>
        <div class="${c.type === 'Radio' ? 'seg' : 'chips'}" id="cust-${c.id}">
        ${c.options.map(o => `
        <button
        class="${c.type === 'Radio' ? '' : 'chip'} ${modalSelections[c.id].includes(o.id) ? 'on' : ''}"
        data-cust-id="${c.id}"
        data-opt-id="${o.id}"
        data-type="${c.type}"
        data-price="${o.priceModifier}">
        ${o.label}${o.priceModifier > 0 ? ` (+₱${money(o.priceModifier)})` : ''}
        </button>`).join('')}
        </div>`;
        custEl.appendChild(group);
        });

        // ── Render addons from DB ──────────────────────────────────────────────
        const addonEl = $('#mAddons');
        addonEl.innerHTML = '';
        if ((it.addons || []).length) {
        const group = document.createElement('div');
        group.className = 'opt-group';
        group.innerHTML = `
        <div class="opt-label">Add-ons</div>
        <div class="chips" id="addon-chips">
        ${it.addons.map(a => `
        <button class="chip"
        data-addon-id="${a.id}"
        data-price="${a.price}">
        ${a.name}${a.price > 0 ? ` (+₱${money(a.price)})` : ''}
        </button>`).join('')}
        </div>`;
        addonEl.appendChild(group);
        }

        // Wire up customization buttons
        $$('[data-cust-id]').forEach(btn => btn.addEventListener('click', () => {
        const cid  = btn.dataset.custId;
        const oid  = btn.dataset.optId;
        const type = btn.dataset.type;

        if (type === 'Radio') {
        modalSelections[cid] = [oid];
        $$(`[data-cust-id="${cid}"]`).forEach(b =>
        b.classList.toggle('on', b.dataset.optId === oid));
        } else {
        const sel = modalSelections[cid] || [];
        if (sel.includes(oid)) {
        modalSelections[cid] = sel.filter(x => x !== oid);
        btn.classList.remove('on');
        } else {
        modalSelections[cid] = [...sel, oid];
        btn.classList.add('on');
        }
        }
        updateModalPrice();
        }));

        // Wire up addon buttons
        $$('[data-addon-id]').forEach(btn => btn.addEventListener('click', () => {
        const aid = btn.dataset.addonId;
        if (modalAddons[aid]) {
        delete modalAddons[aid];
        btn.classList.remove('on');
        } else {
        modalAddons[aid] = parseFloat(btn.dataset.price);
        btn.classList.add('on');
        }
        updateModalPrice();
        }));

        updateModalPrice();
        $('#modal').classList.add('show');
        }

        function closeModal() { $('#modal').classList.remove('show'); }

        function calcModalUnit() {
        if (!editing) return 0;
        let total = editing.price;

        // Add customization price modifiers
        Object.entries(modalSelections).forEach(([cid, optIds]) => {
        const cust = (editing.customizations || []).find(c => c.id == cid);
        if (!cust) return;
        optIds.forEach(oid => {
        const opt = cust.options.find(o => o.id == oid);
        if (opt) total += opt.priceModifier;
        });
        });

        // Add addon prices
        Object.values(modalAddons).forEach(p => total += p);

        return total;
        }

        function updateModalPrice() {
        $('#mPrice').textContent = money(calcModalUnit() * modalQty);
        }

        function changeQty(d) {
        modalQty = Math.max(1, Math.min(9, modalQty + d));
        $('#qty').textContent = modalQty;
        updateModalPrice();
        }

        // ── Add to cart ────────────────────────────────────────────────────────────
        function addToCart() {
        const mods = [];

        // Customization labels
        Object.entries(modalSelections).forEach(([cid, optIds]) => {
        const cust = (editing.customizations || []).find(c => c.id == cid);
        if (!cust) return;
        optIds.forEach(oid => {
        const opt = cust.options.find(o => o.id == oid);
        if (opt) mods.push(opt.label);
        });
        });

        // Addon labels
        Object.keys(modalAddons).forEach(aid => {
        const addon = (editing.addons || []).find(a => a.id == aid);
        if (addon) mods.push(addon.name);
        });

        cart.push({
        id:    Date.now(),
        name:  editing.name,
        image: editing.image || null,
        unit:  calcModalUnit(),
        qty:   modalQty,
        mods,
        // raw for order submission
        itemId:     editing.id,
        selections: { ...modalSelections },
        addons:     { ...modalAddons }
        });

        closeModal();
        updateCartFab(true);
        }

        function updateCartFab(bump) {
        const count = cart.reduce((a, c) => a + c.qty, 0);
        const total = cart.reduce((a, c) => a + c.qty * c.unit, 0);
        $('#fabCount').textContent = count;
        $('#fabTotal').textContent = money(total);
        const fab = $('#cartFab');
        fab.classList.toggle('hidden', count === 0);
        if (bump) { fab.classList.remove('bump'); void fab.offsetWidth; fab.classList.add('bump'); }
        }

        // ── Cart screen ────────────────────────────────────────────────────────────
        function renderCart() {
        const wrap = $('#lines');
        if (!cart.length) {
        wrap.innerHTML = `<div class="cart-empty">
        <i class="fa-solid fa-basket-shopping"></i>
        <p>Your cart is empty</p>
        </div>`;
        } else {
        wrap.innerHTML = cart.map(l => `
        <div class="line">
        <div class="ico">
        ${l.image
        ? `<img src="${l.image}" alt="${l.name}" />`
        : `<i class="fa-solid fa-mug-hot"></i>`}
        </div>
        <div>
        <h5>${l.qty} × ${l.name}</h5>
        <div class="mods">${l.mods.join(' · ') || 'No customizations'}</div>
        <button class="remove" onclick="removeLine(${l.id})">
        <i class="fa-regular fa-trash-can"></i> Remove
        </button>
        </div>
        <div class="price">₱${money(l.qty * l.unit)}</div>
        </div>`).join('');
        }

        const subtotal = cart.reduce((a, c) => a + c.qty * c.unit, 0);
        const tax      = subtotal * 0.12;
        $('#sub').textContent = money(subtotal);
        $('#tax').textContent = money(tax);
        $('#tot').textContent = money(subtotal + tax);
        $('#place').disabled  = cart.length === 0;
        }

        function removeLine(id) {
        cart = cart.filter(l => l.id !== id);
        renderCart();
        updateCartFab();
        }

        // ── Place order ────────────────────────────────────────────────────────────
        async function placeOrder() {
        const btn = $('#place');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Placing…';

        const subtotal = cart.reduce((a, c) => a + c.qty * c.unit, 0);
        const tax      = subtotal * 0.12;
        const total    = subtotal + tax;

        const totalQty  = cart.reduce((a, c) => a + c.qty, 0);
        const totalPrep = cart.reduce((a, c) => {
        const it = items.find(i => i.id == c.itemId);
        return a + (it ? it.prepTime : 5) * c.qty;
        }, 0);
        const avgPrep = Math.ceil(totalPrep / totalQty);

        const payload = {
        customerName:     'Walk-in',
        orderType:        'take-out',
        tableNumber:      null,
        paymentMethod:    'Cash',
        estimatedMinutes: avgPrep,
        items: cart.map(l => ({
        menuItemId:          String(l.itemId),
        name:                l.name,
        quantity:            l.qty,
        unitPrice:           l.unit,
        customization:       l.mods.join(', '),
        specialInstructions: ''
        }))
        };

        try {
        const res = await fetch('/api/orders/place', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload)
        });

        if (!res.ok) {
        const errText = await res.text();
        throw new Error(errText || `HTTP ${res.status}`);
        }

        const data = await res.json();

        // ── inline so there's no reference issue ──────────────────────────
        showOrderSlip(data.orderNumber, subtotal, tax, total, avgPrep);

        } catch (err) {
        alert('Could not place order: ' + err.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-lock"></i> Place Order';
        }
        }

        function showOrderSlip(orderNumber, subtotal, tax, total, avgPrep) {
        const numOnly = String(orderNumber).replace(/\D/g, '') || orderNumber;
        $('#conf-num').textContent   = numOnly;
        $('#conf-type').textContent  = $('#orderType').textContent || 'Takeaway';
        $('#conf-sub').textContent   = money(subtotal);
        $('#conf-tax').textContent   = money(tax);
        $('#conf-total').textContent = money(total);
        $('#conf-eta').textContent   = `${avgPrep}–${avgPrep + 3}`;

        $('#conf-items').innerHTML = cart.map(l => `
        <div style="display:flex;justify-content:space-between;align-items:flex-start;
        padding:10px 0;border-bottom:1px solid var(--line);">
        <div style="flex:1;padding-right:12px;">
        <div style="font-size:14px;font-weight:700;">${l.qty}× ${l.name}</div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px;">
        ${l.mods.length ? l.mods.join(' · ') : 'No customizations'}
        </div>
        </div>
        <div style="font-size:14px;font-weight:700;white-space:nowrap;">
        ₱${money(l.qty * l.unit)}
        </div>
        </div>`).join('');

        $('#confirm-overlay').classList.add('show');
        }

        // ── Reset ──────────────────────────────────────────────────────────────────
        function resetAll() {
        cart       = [];
        currentCat = categories.length ? categories[0].id : null;
        if (currentCat) {
        const cat = categories.find(c => c.id === currentCat);
        $('#catTitle').textContent = cat?.name || 'Menu';
        $('#catSub').textContent   = cat?.sub  || '';
        }
        $('#search').value = '';

        // Close order slip
        $('#confirm-overlay').classList.remove('show');

        // Reset place button
        const btn = $('#place');
        btn.disabled  = false;
        btn.innerHTML = '<i class="fa-solid fa-lock"></i> Place Order';

        renderCats();
        renderGrid();
        updateCartFab();
        showScreen('welcome');
        }

        // ── Init ───────────────────────────────────────────────────────────────────
        if (categories.length) {
        const first = categories[0];
        $('#catTitle').textContent = first.name;
        $('#catSub').textContent   = first.sub || '';
        }
        renderCats();
        renderGrid();
        updateCartFab();
    </script>
</body>
</html>