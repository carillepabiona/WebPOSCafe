@page
@model WebPOSCafe.Pages.TakeOut.TakeOutMenuModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Verso Cafe — Kiosk</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
  :root{
    --brand:#e47835;
    --brand-dark:#c8631f;
    --brand-soft:#fdeee2;
    --brand-softer:#fff7f0;
    --ink:#1c1917;
    --ink-2:#44403c;
    --muted:#78716c;
    --line:#f0ece8;
    --bg:#ffffff;
    --shadow-sm:0 1px 2px rgba(28,25,23,.05);
    --shadow:0 8px 24px -8px rgba(228,120,53,.18), 0 2px 6px rgba(28,25,23,.04);
    --shadow-lg:0 30px 60px -20px rgba(28,25,23,.18);
    --radius:20px;
    --radius-sm:14px;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  html,body{height:100%}
  body{
    font-family:'Plus Jakarta Sans',system-ui,-apple-system,sans-serif;
    background:var(--bg);
    color:var(--ink);
    overflow:hidden;
    user-select:none;
  }
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
  .app{position:fixed;inset:0;display:flex;flex-direction:column}

  /* ---------- Screens ---------- */
  .screen{position:absolute;inset:0;opacity:0;pointer-events:none;transition:opacity .35s ease, transform .35s ease;transform:translateY(8px);overflow:hidden}
  .screen.active{opacity:1;pointer-events:auto;transform:none}

  /* ---------- Welcome ---------- */
  #welcome{
    background:
      radial-gradient(1200px 600px at 80% -10%, var(--brand-soft), transparent 60%),
      radial-gradient(900px 500px at -10% 110%, #fff3e8, transparent 60%),
      #fff;
    display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;
  }
  .brand-mark{display:flex;align-items:center;gap:14px;margin-bottom:24px}
  .brand-mark .logo{width:64px;height:64px;border-radius:18px;background:var(--brand);display:grid;place-items:center;color:#fff;font-size:30px;box-shadow:var(--shadow)}
  .brand-mark h2{font-size:22px;font-weight:700;letter-spacing:.3em;color:var(--ink-2)}
  .hero-title{font-size:clamp(64px,9vw,140px);font-weight:800;letter-spacing:-.04em;line-height:1;background:linear-gradient(135deg,var(--ink) 0%,var(--brand) 100%);-webkit-background-clip:text;background-clip:text;color:transparent}
  .hero-sub{margin-top:18px;color:var(--muted);font-size:20px;max-width:520px}
  .tiles{display:flex;flex-direction:column;gap:24px;margin-top:60px;width:min(820px,95%); justify-content:center; align-items:center;}
  .tile{background:#fff;border:1px solid var(--line);border-radius:28px;padding:40px 32px;text-align:left;transition:.25s;box-shadow:var(--shadow-sm);justify-content:center; align-items:center; text-align:center}
  .tile:hover,.tile:active{transform:translateY(-4px);border-color:var(--brand);box-shadow:var(--shadow-lg)}
  .tile .icon{width:72px;height:72px;border-radius:20px;background:var(--brand-soft);color:var(--brand);display:grid;place-items:center;font-size:32px;margin-bottom:24px; justify-content:center; align-items:center; text-align:center;}
  .tile h3{font-size:32px;font-weight:700;letter-spacing:-.01em}
  .tile p{color:var(--muted);margin-top:6px;font-size:16px}
  .tile .arrow{margin-top:28px;display:inline-flex;align-items:center;gap:10px;color:var(--brand);font-weight:600}
  .tap-hint{position:absolute;bottom:32px;color:var(--muted);font-size:14px;letter-spacing:.2em;text-transform:uppercase}
  .tile h3 .tile p,.tile .arrow{ text-align:center; }

  /* ---------- Menu ---------- */
  #menu{display:flex;flex-direction:column;background:#fff}
  .topbar{display:flex;align-items:center;justify-content:space-between;padding:18px 28px;border-bottom:1px solid var(--line);background:#fff;z-index:5}
  .topbar .left{display:flex;align-items:center;gap:14px}
  .topbar .logo{width:42px;height:42px;border-radius:12px;background:var(--brand);color:#fff;display:grid;place-items:center;font-size:18px}
  .topbar .name{font-weight:800;letter-spacing:.04em;font-size:18px}
  .order-pill{display:inline-flex;align-items:center;gap:8px;background:var(--brand-soft);color:var(--brand-dark);padding:8px 14px;border-radius:999px;font-weight:600;font-size:13px}
  .topbar .right{display:flex;align-items:center;gap:18px;color:var(--muted);font-size:14px}
  .topbar .startover{display:inline-flex;align-items:center;gap:8px;padding:10px 16px;border-radius:12px;border:1px solid var(--line);font-weight:600;color:var(--ink-2);font-size:14px}
  .topbar .startover:hover{border-color:var(--brand);color:var(--brand)}

  .menu-body{flex:1;display:grid;grid-template-columns:220px 1fr;min-height:0}
  .cats{padding:22px 14px;border-right:1px solid var(--line);overflow-y:auto}
  .cat{display:flex;align-items:center;gap:12px;padding:14px 14px;border-radius:14px;color:var(--ink-2);font-weight:600;font-size:15px;width:100%;text-align:left;margin-bottom:6px;transition:.2s}
  .cat i{width:32px;height:32px;border-radius:10px;background:var(--brand-softer);color:var(--brand);display:grid;place-items:center;font-size:14px}
  .cat:hover{background:#faf7f4}
  .cat.active{background:var(--brand);color:#fff}
  .cat.active i{background:rgba(255,255,255,.18);color:#fff}

  .items-wrap{overflow-y:auto;padding:28px 32px 140px}
  .items-head{display:flex;justify-content:space-between;align-items:end;margin-bottom:22px}
  .items-head h1{font-size:34px;font-weight:800;letter-spacing:-.02em}
  .items-head p{color:var(--muted);margin-top:4px}
  .search{display:flex;align-items:center;gap:10px;background:#faf7f4;border:1px solid var(--line);border-radius:14px;padding:12px 16px;width:300px}
  .search input{border:none;outline:none;background:transparent;width:100%;font:inherit;color:var(--ink)}
  .search i{color:var(--muted)}

  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px}
  .card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:18px;display:flex;flex-direction:column;transition:.2s;cursor:pointer;position:relative;overflow:hidden}
  .card:hover{transform:translateY(-4px);border-color:var(--brand);box-shadow:var(--shadow)}
  .card .thumb{height:130px;border-radius:var(--radius-sm);background:linear-gradient(135deg,var(--brand-softer),var(--brand-soft));display:grid;place-items:center;font-size:54px;color:var(--brand);margin-bottom:14px}
  .card h4{font-size:17px;font-weight:700;letter-spacing:-.01em}
  .card .desc{color:var(--muted);font-size:13px;margin-top:4px;line-height:1.45;flex:1}
  .card .row{display:flex;justify-content:space-between;align-items:center;margin-top:14px}
  .card .price{font-weight:800;font-size:18px}
  .card .add{width:42px;height:42px;border-radius:12px;background:var(--brand);color:#fff;display:grid;place-items:center;font-size:16px;transition:.2s}
  .card .add:hover{background:var(--brand-dark);transform:scale(1.05)}

  /* ---------- Floating cart ---------- */
  .cart-fab{position:absolute;bottom:24px;right:24px;background:var(--brand);color:#fff;padding:16px 22px;border-radius:18px;display:flex;align-items:center;gap:14px;font-weight:700;box-shadow:0 18px 40px -10px rgba(228,120,53,.55);transition:.2s;z-index:10}
  .cart-fab:hover{background:var(--brand-dark);transform:translateY(-2px)}
  .cart-fab .badge{background:rgba(255,255,255,.22);padding:6px 12px;border-radius:999px;font-size:13px}
  .cart-fab.hidden{transform:translateY(120%);opacity:0;pointer-events:none}
  .cart-fab.bump{animation:bump .4s ease}
  @@keyframes bump{0%{transform:scale(1)}40%{transform:scale(1.08)}100%{transform:scale(1)}}

  /* ---------- Modal ---------- */
  .modal-overlay{position:absolute;inset:0;background:rgba(28,25,23,.45);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:.25s;z-index:50}
  .modal-overlay.show{opacity:1;pointer-events:auto}
  .modal{background:#fff;border-radius:28px;width:min(560px,92%);max-height:88vh;overflow:hidden;display:flex;flex-direction:column;transform:translateY(20px);transition:.3s;box-shadow:var(--shadow-lg)}
  .modal-overlay.show .modal{transform:none}
  .modal-head{position:relative;height:180px;background:linear-gradient(135deg,var(--brand-soft),var(--brand-softer));display:grid;place-items:center;font-size:84px;color:var(--brand)}
  .modal-close{position:absolute;top:16px;right:16px;width:40px;height:40px;border-radius:12px;background:rgba(255,255,255,.85);color:var(--ink);display:grid;place-items:center}
  .modal-body{padding:24px 28px;overflow-y:auto;flex:1}
  .modal-body h3{font-size:26px;font-weight:800;letter-spacing:-.02em}
  .modal-body .m-desc{color:var(--muted);margin-top:6px;font-size:14px}
  .opt-group{margin-top:22px}
  .opt-label{font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
  .seg{display:flex;background:#faf7f4;border-radius:14px;padding:4px;border:1px solid var(--line)}
  .seg button{flex:1;padding:12px;border-radius:11px;font-weight:600;color:var(--ink-2);font-size:14px;transition:.2s}
  .seg button.on{background:var(--brand);color:#fff;box-shadow:0 4px 12px -4px rgba(228,120,53,.5)}
  .chips{display:flex;flex-wrap:wrap;gap:8px}
  .chip{padding:10px 16px;border-radius:999px;border:1.5px solid var(--line);font-weight:600;color:var(--ink-2);font-size:14px;transition:.15s}
  .chip.on{border-color:var(--brand);background:var(--brand-soft);color:var(--brand-dark)}
  .sugar{display:flex;align-items:center;gap:14px}
  .sugar input[type=range]{flex:1;accent-color:var(--brand)}
  .sugar .val{font-weight:700;width:32px;text-align:center}
  .modal-foot{padding:18px 28px;border-top:1px solid var(--line);display:flex;align-items:center;gap:14px}
  .stepper{display:flex;align-items:center;background:#faf7f4;border:1px solid var(--line);border-radius:14px;padding:4px}
  .stepper button{width:38px;height:38px;border-radius:10px;color:var(--brand);font-size:14px}
  .stepper button:hover{background:#fff}
  .stepper .qty{width:36px;text-align:center;font-weight:700}
  .add-btn{flex:1;background:var(--brand);color:#fff;padding:16px;border-radius:14px;font-weight:700;font-size:15px;display:flex;align-items:center;justify-content:space-between;transition:.2s}
  .add-btn:hover{background:var(--brand-dark)}

  /* ---------- Cart screen ---------- */
  #cart{background:#fff;display:flex;flex-direction:column}
  .cart-body{flex:1;display:grid;grid-template-columns:1.4fr 1fr;min-height:0}
  .cart-list{overflow-y:auto;padding:28px 32px;border-right:1px solid var(--line)}
  .cart-list h1{font-size:30px;font-weight:800;letter-spacing:-.02em;margin-bottom:6px}
  .cart-list .sub{color:var(--muted);margin-bottom:22px}
  .line{display:grid;grid-template-columns:64px 1fr auto;gap:16px;padding:18px 0;border-bottom:1px solid var(--line);align-items:center}
  .line .ico{width:64px;height:64px;border-radius:14px;background:var(--brand-softer);color:var(--brand);display:grid;place-items:center;font-size:26px}
  .line h5{font-weight:700;font-size:16px}
  .line .mods{color:var(--muted);font-size:13px;margin-top:4px}
  .line .price{font-weight:800;font-size:16px;text-align:right}
  .line .remove{margin-top:6px;color:var(--muted);font-size:12px;display:inline-flex;align-items:center;gap:6px}
  .line .remove:hover{color:var(--brand)}
  .cart-empty{text-align:center;color:var(--muted);padding:80px 20px}
  .cart-empty i{font-size:60px;color:var(--brand);margin-bottom:14px;opacity:.5}

  .checkout{padding:28px;display:flex;flex-direction:column;background:#fafaf9}
  .summary{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:22px;margin-bottom:18px}
  .summary h4{font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
  .srow{display:flex;justify-content:space-between;padding:6px 0;font-size:15px;color:var(--ink-2)}
  .srow.total{border-top:1px dashed var(--line);margin-top:10px;padding-top:14px;font-weight:800;font-size:22px;color:var(--ink)}
  .pay h4{font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
  .pay-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .pay-opt{background:#fff;border:1.5px solid var(--line);border-radius:14px;padding:18px;display:flex;flex-direction:column;align-items:flex-start;gap:8px;transition:.15s}
  .pay-opt i{font-size:22px;color:var(--brand)}
  .pay-opt span{font-weight:600;font-size:14px}
  .pay-opt.on{border-color:var(--brand);background:var(--brand-softer)}
  .place{margin-top:auto;background:var(--brand);color:#fff;padding:18px;border-radius:16px;font-weight:700;font-size:16px;display:flex;align-items:center;justify-content:center;gap:10px;transition:.2s}
  .place:hover{background:var(--brand-dark)}
  .place:disabled{opacity:.5;cursor:not-allowed}
  .back-btn{display:inline-flex;align-items:center;gap:8px;color:var(--ink-2);font-weight:600;font-size:14px;padding:10px 14px;border-radius:12px;border:1px solid var(--line);margin-bottom:18px}
  .back-btn:hover{border-color:var(--brand);color:var(--brand)}

  /* ---------- Confirmation ---------- */
  #confirm{background:#fff;display:flex;align-items:center;justify-content:center;text-align:center;padding:40px}
  .confirm-card{max-width:480px}
  .check{width:120px;height:120px;border-radius:50%;background:var(--brand-soft);color:var(--brand);display:grid;place-items:center;font-size:56px;margin:0 auto 24px;animation:pop .5s ease}
  @@keyframes pop{0%{transform:scale(.5);opacity:0}100%{transform:scale(1);opacity:1}}
  #confirm h1{font-size:38px;font-weight:800;letter-spacing:-.02em}
  #confirm p{color:var(--muted);margin-top:8px;font-size:16px}
  .order-no{margin-top:28px;padding:24px;border:1.5px dashed var(--brand);border-radius:20px;background:var(--brand-softer)}
  .order-no .lbl{font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
  .order-no .num{font-size:48px;font-weight:800;color:var(--brand);letter-spacing:.05em;margin-top:4px}
  .eta{margin-top:18px;color:var(--ink-2);font-size:15px}
  .new-order{margin-top:28px;background:var(--brand);color:#fff;padding:16px 32px;border-radius:14px;font-weight:700;font-size:15px}
  .new-order:hover{background:var(--brand-dark)}
</style>
</head>
<body>
<div class="app">

  <!-- WELCOME -->
  <section class="screen active" id="welcome">
    <div class="brand-mark">
      <div class="logo"><i class="fa-solid fa-mug-saucer"></i></div>
      <h2>VERSO</h2>
    </div>
    <div class="hero-title">Verso Cafe</div>
    <p class="hero-sub">Hand-crafted coffee, fresh pastries, and good mornings — order in seconds.</p>
    <div class="tiles">
      <button class="tile" data-type="Takeaway">
        <div class="icon"><i class="fa-solid fa-bag-shopping"></i></div>
        <h3>Takeaway</h3>
        <p>Grab your order and go</p>
        <span class="arrow">Start order <i class="fa-solid fa-arrow-right"></i></span>
      </button>
    </div>
    <div class="tap-hint">Tap to begin</div>
  </section>

  <!-- MENU -->
  <section class="screen" id="menu">
    <div class="topbar">
      <div class="left">
        <div class="logo"><i class="fa-solid fa-mug-saucer"></i></div>
        <div class="name">VERSO CAFE</div>
        <span class="order-pill"><i class="fa-solid fa-circle" style="font-size:6px"></i> <span id="orderType">Dine In</span></span>
      </div>
      <div class="right">
        <span id="clock"></span>
        <button class="startover" onclick="resetAll()"><i class="fa-solid fa-rotate-left"></i> Start Over</button>
      </div>
    </div>
    <div class="menu-body">
      <aside class="cats" id="cats"></aside>
      <div class="items-wrap">
        <div class="items-head">
          <div>
            <h1 id="catTitle">Coffee</h1>
            <p id="catSub">Freshly brewed, all day</p>
          </div>
          <div class="search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input id="search" placeholder="Search the menu..." />
          </div>
        </div>
        <div class="grid" id="grid"></div>
      </div>
    </div>
    <button class="cart-fab hidden" id="cartFab" onclick="showScreen('cart');renderCart()">
      <i class="fa-solid fa-basket-shopping"></i>
      <span><span id="fabCount">0</span> items</span>
      <span class="badge">$<span id="fabTotal">0.00</span></span>
      <i class="fa-solid fa-arrow-right"></i>
    </button>
  </section>

  <!-- CART -->
  <section class="screen" id="cart">
    <div class="topbar">
      <div class="left">
        <div class="logo"><i class="fa-solid fa-mug-saucer"></i></div>
        <div class="name">VERSO CAFE</div>
        <span class="order-pill"><i class="fa-solid fa-circle" style="font-size:6px"></i> <span class="orderTypeEcho">Dine In</span></span>
      </div>
      <div class="right">
        <button class="startover" onclick="resetAll()"><i class="fa-solid fa-rotate-left"></i> Start Over</button>
      </div>
    </div>
    <div class="cart-body">
      <div class="cart-list">
        <button class="back-btn" onclick="showScreen('menu')"><i class="fa-solid fa-arrow-left"></i> Back to menu</button>
        <h1>Your Order</h1>
        <p class="sub">Review items before checkout</p>
        <div id="lines"></div>
      </div>
      <div class="checkout">
        <div class="summary">
          <h4>Order Summary</h4>
          <div class="srow"><span>Subtotal</span><span>$<span id="sub">0.00</span></span></div>
          <div class="srow"><span>Tax (12%)</span><span>$<span id="tax">0.00</span></span></div>
          <div class="srow total"><span>Total</span><span>$<span id="tot">0.00</span></span></div>
        </div>
        <div class="pay">
          <h4>Payment Method</h4>
          <div class="pay-grid" id="payGrid">
            <button class="pay-opt" data-pay="cash"><i class="fa-solid fa-money-bill-wave"></i><span>Cash at counter</span></button>
          </div>
        </div>
        <button class="place" id="place" onclick="placeOrder()"><i class="fa-solid fa-lock"></i> Place Order</button>
      </div>
    </div>
  </section>

  <!-- CONFIRMATION -->
  <section class="screen" id="confirm">
    <div class="confirm-card">
      <div class="check"><i class="fa-solid fa-check"></i></div>
      <h1>Order Confirmed!</h1>
      <p>Thanks for ordering from Verso Cafe. We're brewing it now.</p>
      <div class="order-no">
        <div class="lbl">Your Order Number</div>
        <div class="num" id="orderNum">A-042</div>
      </div>
      <div class="eta"><i class="fa-regular fa-clock" style="color:var(--brand)"></i> Estimated ready in <strong>6–8 minutes</strong></div>
      <button class="new-order" onclick="resetAll()">Start a New Order</button>
    </div>
  </section>

  <!-- MODAL -->
  <div class="modal-overlay" id="modal">
    <div class="modal">
      <div class="modal-head">
        <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        <i id="mIcon" class="fa-solid fa-mug-hot"></i>
      </div>
      <div class="modal-body">
        <h3 id="mName">Espresso</h3>
        <p class="m-desc" id="mDesc">Bold and aromatic single shot.</p>

        <div class="opt-group">
          <div class="opt-label">Size</div>
          <div class="seg" id="sizeSeg">
            <button data-size="S" data-add="-0.50">Small</button>
            <button class="on" data-size="M" data-add="0">Medium</button>
            <button data-size="L" data-add="1.00">Large</button>
          </div>
        </div>

        <div class="opt-group" id="milkGroup">
          <div class="opt-label">Milk</div>
          <div class="chips" id="milkChips">
            <button class="chip on" data-milk="Whole">Whole</button>
            <button class="chip" data-milk="Oat">Oat (+$0.60)</button>
            <button class="chip" data-milk="Almond">Almond (+$0.60)</button>
            <button class="chip" data-milk="Skim">Skim</button>
          </div>
        </div>

        <div class="opt-group">
          <div class="opt-label">Extras</div>
          <div class="chips" id="extraChips">
            <button class="chip" data-extra="Extra shot" data-add="0.80">Extra shot (+$0.80)</button>
            <button class="chip" data-extra="Vanilla" data-add="0.50">Vanilla (+$0.50)</button>
            <button class="chip" data-extra="Caramel" data-add="0.50">Caramel (+$0.50)</button>
            <button class="chip" data-extra="Whipped" data-add="0.40">Whipped (+$0.40)</button>
          </div>
        </div>

        <div class="opt-group">
          <div class="opt-label">Sugar level</div>
          <div class="sugar">
            <i class="fa-solid fa-cube" style="color:var(--muted)"></i>
            <input type="range" id="sugar" min="0" max="5" value="2" />
            <span class="val" id="sugarVal">2</span>
          </div>
        </div>
      </div>
      <div class="modal-foot">
        <div class="stepper">
          <button onclick="changeQty(-1)"><i class="fa-solid fa-minus"></i></button>
          <span class="qty" id="qty">1</span>
          <button onclick="changeQty(1)"><i class="fa-solid fa-plus"></i></button>
        </div>
        <button class="add-btn" onclick="addToCart()">
          <span>Add to Order</span>
          <span>$<span id="mPrice">3.50</span></span>
        </button>
      </div>
    </div>
  </div>

</div>

<script>
  // ---------- Data ----------
  const categories = [
    {id:'coffee', name:'Coffee', icon:'fa-mug-hot', sub:'Freshly brewed, all day'},
    {id:'espresso', name:'Espresso', icon:'fa-mug-saucer', sub:'Bold shots & classics'},
    {id:'cold', name:'Cold Drinks', icon:'fa-glass-water-droplet', sub:'Iced, frozen, refreshing'},
    {id:'tea', name:'Tea', icon:'fa-leaf', sub:'Loose-leaf selections'},
    {id:'pastries', name:'Pastries', icon:'fa-cookie-bite', sub:'Baked in-house this morning'},
    {id:'breakfast', name:'Breakfast', icon:'fa-egg', sub:'Start your day right'},
  ];

  const items = [
    {id:1,cat:'coffee',name:'House Drip',desc:'Smooth medium roast, single origin.',price:3.20,icon:'fa-mug-hot',milk:true},
    {id:2,cat:'coffee',name:'Café au Lait',desc:'Equal parts coffee and steamed milk.',price:4.20,icon:'fa-mug-hot',milk:true},
    {id:3,cat:'coffee',name:'Cold Brew',desc:'18-hour steeped, smooth and bold.',price:4.80,icon:'fa-glass-water',milk:false},
    {id:4,cat:'espresso',name:'Espresso',desc:'Bold and aromatic single shot.',price:3.00,icon:'fa-mug-saucer',milk:false},
    {id:5,cat:'espresso',name:'Cappuccino',desc:'Espresso with velvety foamed milk.',price:4.50,icon:'fa-mug-hot',milk:true},
    {id:6,cat:'espresso',name:'Latte',desc:'Creamy espresso classic.',price:4.80,icon:'fa-mug-hot',milk:true},
    {id:7,cat:'espresso',name:'Flat White',desc:'Double shot with silky microfoam.',price:4.60,icon:'fa-mug-hot',milk:true},
    {id:8,cat:'espresso',name:'Macchiato',desc:'Espresso marked with foam.',price:4.20,icon:'fa-mug-saucer',milk:true},
    {id:9,cat:'cold',name:'Iced Latte',desc:'Espresso poured over ice and milk.',price:4.90,icon:'fa-martini-glass-citrus',milk:true},
    {id:10,cat:'cold',name:'Iced Americano',desc:'Espresso and cold water.',price:3.80,icon:'fa-glass-water',milk:false},
    {id:11,cat:'cold',name:'Frappé Mocha',desc:'Blended ice, espresso, chocolate.',price:5.60,icon:'fa-ice-cream',milk:true},
    {id:12,cat:'tea',name:'Earl Grey',desc:'Black tea with bergamot.',price:3.50,icon:'fa-leaf',milk:false},
    {id:13,cat:'tea',name:'Matcha Latte',desc:'Stone-ground matcha with milk.',price:5.20,icon:'fa-leaf',milk:true},
    {id:14,cat:'tea',name:'Chamomile',desc:'Calm, floral and caffeine-free.',price:3.40,icon:'fa-seedling',milk:false},
    {id:15,cat:'pastries',name:'Butter Croissant',desc:'Flaky, golden, French butter.',price:3.80,icon:'fa-bread-slice',milk:false},
    {id:16,cat:'pastries',name:'Almond Danish',desc:'Almond cream, toasted slivers.',price:4.20,icon:'fa-cookie',milk:false},
    {id:17,cat:'pastries',name:'Chocolate Muffin',desc:'Double chocolate, soft center.',price:3.60,icon:'fa-cookie-bite',milk:false},
    {id:18,cat:'breakfast',name:'Avocado Toast',desc:'Sourdough, avo, chili, lemon.',price:8.50,icon:'fa-bread-slice',milk:false},
    {id:19,cat:'breakfast',name:'Bacon & Egg Roll',desc:'Brioche, crispy bacon, fried egg.',price:9.20,icon:'fa-burger',milk:false},
    {id:20,cat:'breakfast',name:'Greek Yogurt Bowl',desc:'Berries, honey, granola.',price:7.40,icon:'fa-bowl-food',milk:false},
  ];

  // ---------- State ----------
  let currentCat = 'coffee';
  let cart = [];
  let editing = null; // item being customized
  let modalState = {qty:1, size:'M', sizeAdd:0, milk:'Whole', extras:[], extrasAdd:0, sugar:2};
  let payment = 'card';

  // ---------- Helpers ----------
  const $ = (s,p=document)=>p.querySelector(s);
  const $$ = (s,p=document)=>[...p.querySelectorAll(s)];
  const money = n => n.toFixed(2);

  function showScreen(id){
    $$('.screen').forEach(s=>s.classList.toggle('active', s.id===id));
  }

  // ---------- Welcome ----------
  $$('#welcome .tile').forEach(t=>t.addEventListener('click',()=>{
    $('#orderType').textContent = t.dataset.type;
    $$('.orderTypeEcho').forEach(el=>el.textContent = t.dataset.type);
    showScreen('menu');
  }));

  // ---------- Clock ----------
  function tickClock(){
    const d = new Date();
    $('#clock').innerHTML = '<i class="fa-regular fa-clock"></i> ' + d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
  }
  tickClock(); setInterval(tickClock,30000);

  // ---------- Categories ----------
  function renderCats(){
    $('#cats').innerHTML = categories.map(c=>`
      <button class="cat ${c.id===currentCat?'active':''}" data-id="${c.id}">
        <i class="fa-solid ${c.icon}"></i> ${c.name}
      </button>`).join('');
    $$('#cats .cat').forEach(b=>b.addEventListener('click',()=>{
      currentCat = b.dataset.id;
      const c = categories.find(x=>x.id===currentCat);
      $('#catTitle').textContent = c.name;
      $('#catSub').textContent = c.sub;
      $('#search').value='';
      renderCats();
      renderGrid();
    }));
  }

  function renderGrid(filter=''){
    const q = filter.trim().toLowerCase();
    const list = items.filter(i => (q ? (i.name+i.desc).toLowerCase().includes(q) : i.cat===currentCat));
    $('#grid').innerHTML = list.length ? list.map(i=>`
      <div class="card" data-id="${i.id}">
        <div class="thumb"><i class="fa-solid ${i.icon}"></i></div>
        <h4>${i.name}</h4>
        <p class="desc">${i.desc}</p>
        <div class="row">
          <span class="price">$${money(i.price)}</span>
          <button class="add"><i class="fa-solid fa-plus"></i></button>
        </div>
      </div>`).join('') : `<p style="color:var(--muted)">No items found.</p>`;
    $$('#grid .card').forEach(c=>c.addEventListener('click',()=>openModal(+c.dataset.id)));
  }

  $('#search').addEventListener('input', e=>renderGrid(e.target.value));

  // ---------- Modal ----------
  function openModal(id){
    const it = items.find(i=>i.id===id);
    editing = it;
    modalState = {qty:1, size:'M', sizeAdd:0, milk:'Whole', extras:[], extrasAdd:0, sugar:2};
    $('#mName').textContent = it.name;
    $('#mDesc').textContent = it.desc;
    $('#mIcon').className = 'fa-solid ' + it.icon;
    $('#qty').textContent = 1;
    $('#sugar').value = 2; $('#sugarVal').textContent = 2;
    $$('#sizeSeg button').forEach(b=>b.classList.toggle('on', b.dataset.size==='M'));
    $$('#milkChips .chip').forEach(b=>b.classList.toggle('on', b.dataset.milk==='Whole'));
    $$('#extraChips .chip').forEach(b=>b.classList.remove('on'));
    $('#milkGroup').style.display = it.milk ? '' : 'none';
    updateModalPrice();
    $('#modal').classList.add('show');
  }
  function closeModal(){ $('#modal').classList.remove('show'); }

  $$('#sizeSeg button').forEach(b=>b.addEventListener('click',()=>{
    $$('#sizeSeg button').forEach(x=>x.classList.remove('on'));
    b.classList.add('on');
    modalState.size = b.dataset.size;
    modalState.sizeAdd = parseFloat(b.dataset.add);
    updateModalPrice();
  }));
  $$('#milkChips .chip').forEach(b=>b.addEventListener('click',()=>{
    $$('#milkChips .chip').forEach(x=>x.classList.remove('on'));
    b.classList.add('on');
    modalState.milk = b.dataset.milk;
    updateModalPrice();
  }));
  $$('#extraChips .chip').forEach(b=>b.addEventListener('click',()=>{
    b.classList.toggle('on');
    const ex=[],names=[];let add=0;
    $$('#extraChips .chip.on').forEach(x=>{names.push(x.dataset.extra); add+=parseFloat(x.dataset.add)});
    modalState.extras = names;
    modalState.extrasAdd = add;
    updateModalPrice();
  }));
  $('#sugar').addEventListener('input',e=>{
    modalState.sugar = +e.target.value;
    $('#sugarVal').textContent = e.target.value;
  });
  function changeQty(d){
    modalState.qty = Math.max(1, Math.min(9, modalState.qty + d));
    $('#qty').textContent = modalState.qty;
    updateModalPrice();
  }
  function milkAdd(){ return (modalState.milk==='Oat'||modalState.milk==='Almond') ? 0.60 : 0; }
  function modalUnit(){ return editing.price + modalState.sizeAdd + modalState.extrasAdd + milkAdd(); }
  function updateModalPrice(){ $('#mPrice').textContent = money(modalUnit()*modalState.qty); }

  function addToCart(){
    const mods = [];
    mods.push(modalState.size==='S'?'Small':modalState.size==='L'?'Large':'Medium');
    if(editing.milk) mods.push(modalState.milk+' milk');
    if(modalState.extras.length) mods.push(...modalState.extras);
    mods.push('Sugar '+modalState.sugar);
    cart.push({
      id: Date.now(),
      name: editing.name, icon: editing.icon,
      unit: modalUnit(), qty: modalState.qty, mods
    });
    closeModal();
    updateCartFab(true);
  }

  function updateCartFab(bump){
    const count = cart.reduce((a,c)=>a+c.qty,0);
    const total = cart.reduce((a,c)=>a+c.qty*c.unit,0);
    $('#fabCount').textContent = count;
    $('#fabTotal').textContent = money(total);
    const fab = $('#cartFab');
    fab.classList.toggle('hidden', count===0);
    if(bump){fab.classList.remove('bump'); void fab.offsetWidth; fab.classList.add('bump');}
  }

  // ---------- Cart screen ----------
  function renderCart(){
    const wrap = $('#lines');
    if(!cart.length){
      wrap.innerHTML = `<div class="cart-empty"><i class="fa-solid fa-basket-shopping"></i><p>Your cart is empty</p></div>`;
    } else {
      wrap.innerHTML = cart.map(l=>`
        <div class="line">
          <div class="ico"><i class="fa-solid ${l.icon}"></i></div>
          <div>
            <h5>${l.qty} × ${l.name}</h5>
            <div class="mods">${l.mods.join(' · ')}</div>
            <button class="remove" onclick="removeLine(${l.id})"><i class="fa-regular fa-trash-can"></i> Remove</button>
          </div>
          <div class="price">$${money(l.qty*l.unit)}</div>
        </div>`).join('');
    }
    const sub = cart.reduce((a,c)=>a+c.qty*c.unit,0);
    const tax = sub*0.08;
    $('#sub').textContent = money(sub);
    $('#tax').textContent = money(tax);
    $('#tot').textContent = money(sub+tax);
    $('#place').disabled = cart.length===0;
  }
  function removeLine(id){
    cart = cart.filter(l=>l.id!==id);
    renderCart();
    updateCartFab();
  }

  $$('#payGrid .pay-opt').forEach(p=>p.addEventListener('click',()=>{
    $$('#payGrid .pay-opt').forEach(x=>x.classList.remove('on'));
    p.classList.add('on');
    payment = p.dataset.pay;
  }));

  function placeOrder(){
    const num = 'A-' + String(Math.floor(Math.random()*900)+100);
    $('#orderNum').textContent = num;
    showScreen('confirm');
  }

  function resetAll(){
    cart = [];
    currentCat = 'coffee';
    $('#catTitle').textContent = 'Coffee';
    $('#catSub').textContent = categories[0].sub;
    renderCats(); renderGrid(); updateCartFab();
    showScreen('welcome');
  }

  // ---------- Init ----------
  renderCats();
  renderGrid();
  updateCartFab();
</script>
</body>
</html>
