@page
@model WebPOSCafe.Pages.Admin.MenuDisplayModel

@{
    ViewData["Title"] = "Menu Display";
    ViewData["Subtitle"] = "Browse all items with customizations & add-ons";
}

<link rel="stylesheet" href="~/css/display.css" />

<!-- ── Customer Menu Link ────────────────────────────────────── -->
<a href="/Menu/MenuDisplay" class="btn-primary">
    Open Customer Menu
</a>
<!-- ── Category Filter Bar ──────────────────────────────────── -->
<div class="md-filter-bar">
    <button class="md-cat-btn @(Model.ActiveCategory == "all" ? "active" : "")"
            onclick="filterByCategory('all')" data-cat="all">
        <span class="md-cat-dot" style="background:#8B4513"></span>
        All Items
        <span class="md-cat-count">
            @Model.Categories.Sum(c => c.Items.Count)
        </span>
    </button>
    @foreach (var cat in Model.Categories)
    {
        <button class="md-cat-btn @(Model.ActiveCategory == cat.Id ? "active" : "")"
                onclick="filterByCategory('@cat.Id')" data-cat="@cat.Id">
            <span class="md-cat-dot" style="background:@cat.Color"></span>
            @cat.Name
            <span class="md-cat-count">@cat.Items.Count</span>
        </button>
    }
</div>

<!-- ── Search ────────────────────────────────────────────────── -->
<div class="md-search-wrap">
    <i class="ti ti-search"></i>
    <input class="md-search" type="text" id="mdSearch"
           placeholder="Search menu items…" oninput="searchItems()" />
</div>

<!-- ── Menu Sections ─────────────────────────────────────────── -->
<div id="mdContent">
    @if (!Model.Categories.Any())
    {
        <div class="md-empty">
            <i class="ti ti-coffee"></i>
            <p>No menu items found.</p>
        </div>
    }

    @foreach (var cat in Model.Categories)
    {
        <section class="md-section" data-cat-id="@cat.Id" id="section-@cat.Id">

            <!-- Category heading -->
            <div class="md-section-header">
                <span class="md-section-color" style="background:@cat.Color"></span>
                <h2 class="md-section-title">@cat.Name</h2>
                <span class="md-section-count">@cat.Items.Count item@(cat.Items.Count != 1 ? "s" : "")</span>
            </div>

            <!-- Items grid -->
            <div class="md-items-grid">
                @foreach (var item in cat.Items)
                {
                    <div class="md-item-card @(!item.IsAvailable ? "md-item-unavailable" : "")"
                         data-name="@item.Name.ToLower()"
                         data-cat="@cat.Id">

                        <!-- Thumbnail -->
                        <div class="md-item-thumb">
                            @if (!string.IsNullOrEmpty(item.ImageBase64))
                            {
                                <img src="data:@item.ImageMimeType;base64,@item.ImageBase64"
                                     alt="@item.Name" />
                            }
                            else
                            {
                                <div class="md-thumb-placeholder">
                                    <i class="ti ti-coffee"></i>
                                </div>
                            }
                            @if (!item.IsAvailable)
                            {
                                <div class="md-unavail-overlay">Unavailable</div>
                            }
                        </div>

                        <!-- Item body -->
                        <div class="md-item-body">
                            <div class="md-item-top">
                                <h3 class="md-item-name">@item.Name</h3>
                                <span class="md-item-price">₱@item.Price.ToString("0.00")</span>
                            </div>

                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="md-item-desc">@item.Description</p>
                            }

                            <div class="md-item-meta">
                                <span class="md-meta-chip">
                                    <i class="ti ti-clock"></i> @item.PreparationTime min
                                </span>
                                @if (item.Customizations.Any())
                                {
                                    <span class="md-meta-chip md-chip-cust">
                                        <i class="ti ti-adjustments"></i>
                                        @item.Customizations.Count customization@(item.Customizations.Count != 1 ? "s" : "")
                                    </span>
                                }
                                @if (item.Addons.Any())
                                {
                                    <span class="md-meta-chip md-chip-addon">
                                        <i class="ti ti-plus"></i>
                                        @item.Addons.Count add-on@(item.Addons.Count != 1 ? "s" : "")
                                    </span>
                                }
                            </div>

                            <!-- ── Customizations ─────────────────────────── -->
                            @if (item.Customizations.Any())
                            {
                                <div class="md-section-block">
                                    <div class="md-block-title">
                                        <i class="ti ti-adjustments-alt"></i>
                                        Customizations
                                    </div>
                                    @foreach (var cust in item.Customizations)
                                    {
                                        <div class="md-cust-group">
                                            <div class="md-cust-header">
                                                <span class="md-cust-name">@cust.Name</span>
                                                <div class="md-cust-badges">
                                                    <span class="md-type-badge @(cust.Type == "Radio" ? "badge-radio" : "badge-check")">
                                                        @cust.Type
                                                    </span>
                                                    @if (cust.IsRequired)
                                                    {
                                                        <span class="md-required-badge">Required</span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="md-cust-options">
                                                @foreach (var opt in cust.Options)
                                                {
                                                    <div class="md-opt-row @(opt.IsDefault ? "md-opt-default" : "")">
                                                        <span class="md-opt-indicator @(cust.Type == "Radio" ? "opt-radio" : "opt-check")"></span>
                                                        <span class="md-opt-label">@opt.Label</span>
                                                        @if (opt.PriceModifier != 0)
                                                        {
                                                            <span class="md-opt-price">
                                                                @(opt.PriceModifier > 0 ? "+" : "")₱@opt.PriceModifier.ToString("0.00")
                                                            </span>
                                                        }
                                                        @if (opt.IsDefault)
                                                        {
                                                            <span class="md-opt-default-tag">default</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- ── Add-ons ─────────────────────────────────── -->
                            @if (item.Addons.Any())
                            {
                                <div class="md-section-block md-addons-block">
                                    <div class="md-block-title">
                                        <i class="ti ti-plus-minus"></i>
                                        Add-ons
                                    </div>
                                    <div class="md-addons-grid">
                                        @foreach (var addon in item.Addons)
                                        {
                                            <div class="md-addon-chip">
                                                <span class="md-addon-name">@addon.Name</span>
                                                @if (!string.IsNullOrEmpty(addon.Category))
                                                {
                                                    <span class="md-addon-cat">@addon.Category</span>
                                                }
                                                <span class="md-addon-price">+₱@addon.Price.ToString("0.00")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (!item.Customizations.Any() && !item.Addons.Any())
                            {
                                <div class="md-no-options">
                                    <i class="ti ti-minus"></i> No customizations or add-ons
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        let activeCategory = '@Model.ActiveCategory';

        function filterByCategory(catId) {
            activeCategory = catId;

            document.querySelectorAll('.md-cat-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.cat === catId);
            });

            document.querySelectorAll('.md-section').forEach(section => {
                section.style.display =
                    (catId === 'all' || section.dataset.catId === catId) ? '' : 'none';
            });

            searchItems();
        }

        function searchItems() {
            const q = document.getElementById('mdSearch').value.toLowerCase().trim();

            document.querySelectorAll('.md-item-card').forEach(card => {
                const name    = card.dataset.name || '';
                const catId   = card.dataset.cat  || '';
                const catOk   = activeCategory === 'all' || catId === activeCategory;
                const nameOk  = !q || name.includes(q);
                card.style.display = (catOk && nameOk) ? '' : 'none';
            });

            document.querySelectorAll('.md-section').forEach(section => {
                const cid = section.dataset.catId;
                if (activeCategory !== 'all' && cid !== activeCategory) {
                    section.style.display = 'none';
                    return;
                }
                const visible = section.querySelectorAll('.md-item-card:not([style*="display: none"])');
                section.style.display = visible.length > 0 ? '' : 'none';
            });
        }
    </script>
}
