@page
@model WebPOSCafe.Pages.Admin.MenuManagementModel

@{
    ViewData["Title"] = "Menu Management";
    ViewData["Subtitle"] = "Organize products, categories, add-ons & pricing";
}

@section TopbarActions {
    <button class="btn-primary-cafe" onclick="openAddItemModal()">
        <i class="ti ti-plus"></i> Add New Item
    </button>
    <a class="btn-secondary-cafe" asp-page="/Admin/MenuDisplay">
        <i class="ti ti-eye"></i> View Menu Display
    </a>
}

<!-- ── Error Banner ──────────────────────────────────────────── -->
@if (TempData["Error"] != null)
{
    <div class="error-banner" id="errorBanner">
        <span>@TempData["Error"]</span>
        <button class="close-btn" onclick="document.getElementById('errorBanner').remove()">×</button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="success-banner" id="successBanner">
        <i class="ti ti-circle-check"></i> @TempData["Success"]
    </div>
}

<head>
    <link rel="stylesheet" href="~/css/menu-management.css" />
</head>

<!-- ── Tabs ──────────────────────────────────────────────────── -->
<div class="mm-tabs">
    <button class="mm-tab @(Model.ActiveTab == "items" ? "active" : "")" onclick="switchTab('items')">Menu Items</button>
    <button class="mm-tab @(Model.ActiveTab == "categories" ? "active" : "")" onclick="switchTab('categories')">Categories</button>
    <button class="mm-tab @(Model.ActiveTab == "customizations" ? "active" : "")" onclick="switchTab('customizations')">Customizations</button>
    <button class="mm-tab @(Model.ActiveTab == "addons" ? "active" : "")" onclick="switchTab('addons')">Add-ons</button>
    <button class="mm-tab @(Model.ActiveTab == "availability" ? "active" : "")" onclick="switchTab('availability')">Availability</button>
    <button class="mm-tab @(Model.ActiveTab == "pricing" ? "active" : "")" onclick="switchTab('pricing')">Pricing</button>
</div>

<input type="hidden" id="activeTabInput" name="activeTab" value="@Model.ActiveTab" />

<!-- ══════════════════════════════════════════════════════════════
     TAB: MENU ITEMS
══════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-items" style="display:@(Model.ActiveTab == "items" ? "block" : "none")">

    <div class="section-bar">
        <div class="search-wrap">
            <i class="ti ti-search search-ico"></i>
            <input class="search-input" type="text" id="itemSearch" placeholder="Search items…"
                   oninput="filterItems()" />
        </div>
        <select class="filter-select" id="catFilter" onchange="filterItems()">
            <option value="">All Categories</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.CategoryName">@c.CategoryName</option>
            }
        </select>
    </div>

    <div class="items-grid" id="itemsGrid">
        @foreach (var item in Model.MenuItems)
        {
            <div class="item-card" data-name="@item.Name.ToLower()" data-cat="@item.CategoryName">
                <div class="item-thumb">
                    @if (!string.IsNullOrEmpty(item.ImageBase64))
                    {
                        <img src="data:@item.ImageMimeType;base64,@item.ImageBase64" alt="@item.Name" />
                    }
                    else
                    {
                        <div class="item-thumb-placeholder">
                            <i class="ti ti-photo" style="font-size:28px;color:var(--text-mute)"></i>
                        </div>
                    }
                    <span class="avail-badge @(item.IsAvailable ? "avail-on" : "avail-off")">
                        @(item.IsAvailable ? "Available" : "Unavailable")
                    </span>
                </div>
                <div class="item-body">
                    <div class="item-cat-label">@item.CategoryName</div>
                    <h3 class="item-name">@item.Name</h3>
                    <p class="item-desc">@item.Description</p>
                    <div class="item-meta">
                        <span class="meta-chip">
                            <i class="ti ti-clock" style="font-size:12px"></i>
                            @item.PreparationTime min
                        </span>
                        <span class="meta-price">₱@item.Price.ToString("0.00")</span>
                    </div>
                </div>
                <div class="item-actions">
                    <button class="icon-btn edit-btn" title="Edit"
                            onclick="openEditItemModal(
                        '@item.Id','@Html.Raw(item.Name.Replace("'", "\\'"))','@item.CategoryId',
                        '@Html.Raw((item.Description ?? "").Replace("'", "\\'"))','@item.Price','@item.Cost',
                        '@item.PreparationTime','@item.IsAvailable.ToString().ToLower()',
                        '@item.AvailableFrom','@item.AvailableUntil',
                        '@item.ImageBase64','@item.ImageMimeType')">
                        <i class="ti ti-edit"></i>
                    </button>
                    <button class="icon-btn assign-btn" title="Assign Customizations & Add-ons"
                            onclick="openAssignModal(
                        '@item.Id',
                        '@Html.Raw(item.Name.Replace("'", "\\\'"))',
                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(item.AssignedCustomizationIds)),
                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(item.AssignedAddonIds)))">
                        <i class="ti ti-adjustments-alt"></i>
                    </button>

                    <form method="post" asp-page-handler="ToggleAvailability" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="activeTab" value="items" />
                        <button type="submit"
                                class="icon-btn toggle-btn @(item.IsAvailable ? "toggle-on" : "toggle-off")"
                                title="Toggle availability">
                            <i class="ti ti-circle-check"></i>
                        </button>
                    </form>

                    <form method="post" asp-page-handler="DeleteItem" style="display:inline"
                          onsubmit="return confirm('Delete this item?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="activeTab" value="items" />
                        <button type="submit" class="icon-btn delete-btn" title="Delete">
                            <i class="ti ti-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.MenuItems.Any())
        {
            <div class="empty-state">
                <i class="ti ti-coffee"></i>
                <p>No menu items yet. Click <strong>Add New Item</strong> to get started.</p>
            </div>
        }
    </div>



    <!-- ── Assign Customizations & Add-ons Modal ─────────────────── -->
    <div class="cafe-modal-backdrop" id="assignModalBackdrop" style="display:none" onclick="closeModals()">
        <div class="cafe-modal cafe-modal-lg" onclick="event.stopPropagation()">
            <div class="cafe-modal-header">
                <h2 id="assignModalTitle">Assign Options</h2>
                <button class="cafe-modal-close" onclick="closeModals()">×</button>
            </div>
            <form method="post" asp-page-handler="SaveItemAssignments">
                @Html.AntiForgeryToken()
                <input type="hidden" name="itemId" id="assignItemId" />
                <input type="hidden" name="activeTab" value="items" />
                <div class="cafe-modal-body">

                    <div class="assign-cols">
                        <!-- CUSTOMIZATIONS -->
                        <div class="assign-col">
                            <div class="assign-col-header">
                                <i class="ti ti-adjustments"></i>
                                <span>Customizations</span>
                            </div>
                            <div class="assign-list" id="assignCustomizationsList">
                                @foreach (var cust in Model.Customizations)
                                {
                                    <label class="assign-item">
                                        <input type="checkbox"
                                               name="customizationIds"
                                               value="@cust.Id"
                                               class="assign-checkbox cust-cb"
                                               data-id="@cust.Id" />
                                        <div class="assign-item-info">
                                            <span class="assign-item-name">@cust.Name</span>
                                            <span class="assign-item-sub">
                                                @cust.Type •
                                                @cust.Options.Count option(s)
                                                @(cust.IsRequired ? "• Required" : "")
                                            </span>
                                        </div>
                                        <span class="type-badge @(cust.Type == "Radio" ? "badge-radio" : "badge-check")">
                                            @cust.Type
                                        </span>
                                    </label>
                                }
                                @if (!Model.Customizations.Any())
                                {
                                    <p class="assign-empty">No customizations. Add them in the Customizations tab.</p>
                                }
                            </div>
                        </div>

                        <!-- ADD-ONS -->
                        <div class="assign-col">
                            <div class="assign-col-header">
                                <i class="ti ti-plus-minus"></i>
                                <span>Add-ons</span>
                            </div>
                            <div class="assign-list" id="assignAddonsList">
                                @foreach (var addon in Model.Addons.Where(a => a.IsActive))
                                {
                                    <label class="assign-item">
                                        <input type="checkbox"
                                               name="addonIds"
                                               value="@addon.Id"
                                               class="assign-checkbox addon-cb"
                                               data-id="@addon.Id" />
                                        <div class="assign-item-info">
                                            <span class="assign-item-name">@addon.Name</span>
                                            <span class="assign-item-sub">@addon.Category</span>
                                        </div>
                                        <span class="addon-price-tag">+₱@addon.Price.ToString("0.00")</span>
                                    </label>
                                }
                                @if (!Model.Addons.Any(a => a.IsActive))
                                {
                                    <p class="assign-empty">No active add-ons. Add them in the Add-ons tab.</p>
                                }
                            </div>
                        </div>
                    </div>

                </div>
                <div class="cafe-modal-footer">
                    <button type="button" class="btn-ghost-cafe" onclick="closeModals()">Cancel</button>
                    <button type="submit" class="btn-primary-cafe">
                        <i class="ti ti-device-floppy"></i> Save Assignments
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: CATEGORIES
══════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-categories" style="display:@(Model.ActiveTab == "categories" ? "block" : "none")">

    <div class="section-bar">
        <h2 class="section-title">Categories</h2>
        <button class="btn-secondary-cafe" onclick="openAddCategoryModal()">+ Add Category</button>
    </div>

    <div class="list-container">
        @foreach (var cat in Model.Categories)
        {
            <div class="list-row">
                <div class="cat-dot" style="background:@cat.Color"></div>
                <div class="list-info">
                    <strong>@cat.CategoryName</strong>
                    <span class="list-sub">@cat.Description</span>
                </div>
                <span class="count-badge">@cat.ItemCount items</span>
                <span class="status-chip @(cat.IsActive ? "chip-active" : "chip-inactive")">
                    @(cat.IsActive ? "Active" : "Inactive")
                </span>
                <div class="row-actions">
                    <button class="txt-btn"
                            onclick="openEditCategoryModal('@cat.Id','@Html.Raw(cat.CategoryName.Replace("'", "\\'"))','@Html.Raw((cat.Description ?? "").Replace("'", "\\'"))','@cat.Color','@cat.DisplayOrder','@cat.IsActive.ToString().ToLower()')">
                        Edit
                    </button>
                    <form method="post" asp-page-handler="DeleteCategory" style="display:inline"
                          onsubmit="return confirm('Delete this category and all its items?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cat.Id" />
                        <input type="hidden" name="activeTab" value="categories" />
                        <button type="submit" class="txt-btn danger">Delete</button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.Categories.Any())
        {
            <div class="empty-state">
                <i class="ti ti-tag"></i>
                <p>No categories yet.</p>
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: CUSTOMIZATIONS
══════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-customizations" style="display:@(Model.ActiveTab == "customizations" ? "block" : "none")">

    <div class="section-bar">
        <h2 class="section-title">Customizations</h2>
        <button class="btn-secondary-cafe" onclick="openAddCustomizationModal()">+ Add Customization</button>
    </div>

    <div class="card-grid">
        @foreach (var cust in Model.Customizations)
        {
            <div class="cust-card">
                <div class="cust-card-header">
                    <span class="cust-name">@cust.Name</span>
                    <span class="type-badge @(cust.Type == "Radio" ? "badge-radio" : "badge-check")">@cust.Type</span>
                </div>
                <div class="cust-options">
                    @foreach (var opt in cust.Options)
                    {
                        <div class="opt-row">
                            <span class="opt-dot @(cust.Type == "Radio" ? "dot-radio" : "dot-check")"></span>
                            <span>@opt.OptionLabel</span>
                            @if (opt.PriceModifier != 0)
                            {
                                <span class="opt-price">+₱@opt.PriceModifier.ToString("0.00")</span>
                            }
                        </div>
                    }
                </div>
                <div class="cust-card-footer">
                    <button class="txt-btn" onclick='openEditCustomizationModal(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(cust)))'>Edit</button>
                    <form method="post" asp-page-handler="DeleteCustomization" style="display:inline"
                          onsubmit="return confirm('Delete this customization?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cust.Id" />
                        <input type="hidden" name="activeTab" value="customizations" />
                        <button type="submit" class="txt-btn danger">Delete</button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.Customizations.Any())
        {
            <div class="empty-state">
                <i class="ti ti-adjustments"></i>
                <p>No customizations yet.</p>
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: ADD-ONS
══════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-addons" style="display:@(Model.ActiveTab == "addons" ? "block" : "none")">

    <div class="section-bar">
        <h2 class="section-title">Add-ons</h2>
        <button class="btn-secondary-cafe" onclick="openAddAddonModal()">+ Add Add-on</button>
    </div>

    <div class="list-container">
        @foreach (var addon in Model.Addons)
        {
            <div class="list-row">
                <span class="status-dot-sm @(addon.IsActive ? "dot-on" : "dot-off")"></span>
                <div class="list-info">
                    <strong>@addon.Name</strong>
                    <span class="list-sub">@addon.Category</span>
                </div>
                <span class="addon-price-tag">+₱@addon.Price.ToString("0.00")</span>
                <div class="row-actions">
                    <button class="txt-btn"
                            onclick="openEditAddonModal('@addon.Id','@Html.Raw(addon.Name.Replace("'", "\\'"))','@Html.Raw((addon.Category ?? "").Replace("'", "\\'"))','@addon.Price','@addon.IsActive.ToString().ToLower()')">
                        Edit
                    </button>
                    <form method="post" asp-page-handler="DeleteAddon" style="display:inline"
                          onsubmit="return confirm('Delete this add-on?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@addon.Id" />
                        <input type="hidden" name="activeTab" value="addons" />
                        <button type="submit" class="txt-btn danger">Delete</button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.Addons.Any())
        {
            <div class="empty-state">
                <i class="ti ti-plus-minus"></i>
                <p>No add-ons yet.</p>
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: AVAILABILITY
══════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-availability" style="display:@(Model.ActiveTab == "availability" ? "block" : "none")">

    <div class="section-bar">
        <h2 class="section-title">Availability Schedule</h2>
    </div>

    <div class="avail-grid">
        @foreach (var item in Model.MenuItems)
        {
            <div class="avail-card">
                <div class="avail-header">
                    <span class="avail-name">@item.Name</span>
                    <form method="post" asp-page-handler="ToggleAvailability">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="activeTab" value="availability" />
                        <label class="toggle-switch">
                            <input type="checkbox" @(item.IsAvailable ? "checked" : "")
                                   onchange="this.form.submit()" name="dummy" />
                            <span class="toggle-track"></span>
                        </label>
                    </form>
                </div>
                <form method="post" asp-page-handler="SaveAvailabilityTime">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <input type="hidden" name="activeTab" value="availability" />
                    <div class="avail-times">
                        <div class="time-row">
                            <label>From</label>
                            <input type="time" class="time-input" name="availableFrom"
                                   value="@item.AvailableFrom" onchange="this.form.submit()" />
                        </div>
                        <div class="time-row">
                            <label>Until</label>
                            <input type="time" class="time-input" name="availableUntil"
                                   value="@item.AvailableUntil" onchange="this.form.submit()" />
                        </div>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: PRICING
══════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-pricing" style="display:@(Model.ActiveTab == "pricing" ? "block" : "none")">

    <div class="section-bar">
        <h2 class="section-title">Pricing Management</h2>
    </div>

    <div class="table-wrap">
        <table class="pricing-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Category</th>
                    <th>Price (₱)</th>
                    <th>Cost (₱)</th>
                    <th>Margin</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.MenuItems)
                {
                    var margin = item.Price > 0
                        ? (item.Price - item.Cost) / item.Price * 100
                        : 0;
                    var marginClass = margin >= 50 ? "margin-high" : margin >= 30 ? "margin-mid" : "margin-low";

                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td class="muted">@item.CategoryName</td>
                        <td>₱@item.Price.ToString("0.00")</td>
                        <td class="muted">₱@item.Cost.ToString("0.00")</td>
                        <td>
                            <span class="margin-chip @marginClass">@margin.ToString("0")%</span>
                        </td>
                        <td>
                            <button class="txt-btn"
                                    onclick="openPricingModal('@item.Id','@item.Name','@item.Price','@item.Cost')">
                                Edit
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<!-- ══════════════════════════════════════════════════════════════
     MODALS
══════════════════════════════════════════════════════════════ -->
<!-- ── Add/Edit Menu Item Modal ──────────────────────────────── -->
<div class="modal-backdrop" id="itemModalBackdrop" style="display:none" onclick="closeModals()">
    <div class="modal" onclick="event.stopPropagation()">
        <!-- After (new): -->
        <div class="modal-hdr">
            <div class="modal-hdr-icon">
                <i class="ti ti-coffee"></i>
            </div>
            <div class="modal-hdr-text">
                <h2 id="itemModalTitle">Add New Item</h2>
                <div class="modal-hdr-sub">Fill in the details below</div>
            </div>
            <button class="close-btn" onclick="closeModals()">×</button>
        </div>
        <form method="post" id="itemForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="activeTab" value="items" />
            <input type="hidden" name="Id" id="itemId" />
            <div class="modal-body">

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input class="form-control-cafe" name="Name" id="itemName" required
                               placeholder="e.g., Iced Caramel Latte" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Category *</label>
                        <select class="form-control-cafe" name="CategoryId" id="itemCategoryId" required>
                            <option value="">Select…</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.Id">@c.CategoryName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Price (₱) *</label>
                        <input class="form-control-cafe" type="number" name="Price" id="itemPrice"
                               step="0.01" min="0" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cost (₱)</label>
                        <input class="form-control-cafe" type="number" name="Cost" id="itemCost"
                               step="0.01" min="0" value="0" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea class="form-control-cafe" name="Description" id="itemDescription" rows="3"
                              placeholder="Short description…"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Prep Time (min)</label>
                        <input class="form-control-cafe" type="number" name="PreparationTime"
                               id="itemPrepTime" value="5" min="1" />
                    </div>
                    <div class="form-group" style="display:flex;align-items:flex-end;padding-bottom:4px">
                        <label class="toggle-switch" style="gap:10px;cursor:pointer">
                            <input type="checkbox" name="IsAvailable" id="itemIsAvailable" value="true" checked />
                            <span class="toggle-track"></span>
                            <span style="font-size:13px">Available</span>
                        </label>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Available From</label>
                        <input class="form-control-cafe" type="time" name="AvailableFrom"
                               id="itemAvailFrom" value="06:00" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Available Until</label>
                        <input class="form-control-cafe" type="time" name="AvailableUntil"
                               id="itemAvailUntil" value="22:00" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Product Image</label>
                    <input type="file" class="form-control-cafe" name="ImageFile"
                           id="itemImageFile" accept="image/*" onchange="previewImage(this)" />
                    <img id="itemImagePreview" class="img-preview" style="display:none" />
                    <input type="hidden" name="ExistingImageBase64" id="itemExistingImage" />
                    <input type="hidden" name="ExistingImageMimeType" id="itemExistingMime" />
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-cafe" onclick="closeModals()">Cancel</button>
                <button type="submit" class="btn-primary-cafe" id="itemSaveBtn">Save Item</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Add/Edit Category Modal ───────────────────────────────── -->
<div class="modal-backdrop" id="categoryModalBackdrop" style="display:none" onclick="closeModals()">
    <div class="modal modal-sm" onclick="event.stopPropagation()">
        <div class="modal-hdr">
            <h2 id="categoryModalTitle">Add Category</h2>
        </div>
        <form method="post" id="categoryForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="catId" />
            <input type="hidden" name="activeTab" value="categories" />
            <div class="modal-body">

                <div class="form-group">
                    <label class="form-label">Name *</label>
                    <input class="form-control-cafe" name="CategoryName" id="catName"
                           required placeholder="e.g., Coffee" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input class="form-control-cafe" name="Description" id="catDesc" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <input class="form-control-cafe" type="color" name="Color"
                               id="catColor" value="#8B4513" style="height:42px;padding:4px" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Display Order</label>
                        <input class="form-control-cafe" type="number" name="DisplayOrder"
                               id="catOrder" value="0" min="0" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="toggle-switch" style="gap:10px;cursor:pointer">
                        <input type="checkbox" name="IsActive" id="catIsActive" value="true" checked />
                        <span class="toggle-track"></span>
                        <span style="font-size:13px">Active</span>
                    </label>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost-cafe" onclick="closeModals()">Cancel</button>
                <button type="submit" class="btn-primary-cafe">Save</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Add/Edit Customization Modal ─────────────────────────── -->
<!-- Customization Modal -->
<div class="cafe-modal-backdrop" id="customizationModalBackdrop" style="display:none" onclick="closeModals()">
    <div class="cafe-modal cafe-modal-lg" onclick="event.stopPropagation()">
        <div class="cafe-modal-header">
            <h2 id="custModalTitle">Add Customization</h2>
            <button class="cafe-modal-close" onclick="closeModals()">×</button>
        </div>

        <form method="post" id="custForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="custId" />
            <input type="hidden" name="activeTab" value="customizations" />
            <div class="cafe-modal-body">

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Name *</label>
                        <input class="form-control-cafe" name="Name" id="custName"
                               required placeholder="e.g., Sugar Level" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Type</label>
                        <select class="form-control-cafe" name="Type" id="custType">
