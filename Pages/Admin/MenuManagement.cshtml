                </div>

            </div>
            <div class="cafe-modal-footer">
                <button type="button" class="btn-ghost-cafe" onclick="closeModals()">Cancel</button>
                <button type="submit" class="btn-primary-cafe">Save</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Add/Edit Addon Modal ──────────────────────────────────── -->
<div class="cafe-modal-backdrop" id="addonModalBackdrop" style="display:none" onclick="closeModals()">
    <div class="cafe-modal cafe-modal-sm" onclick="event.stopPropagation()">
        <div class="cafe-modal-header">
            <h2 id="addonModalTitle">Add Add-on</h2>
            <button class="cafe-modal-close" onclick="closeModals()">×</button>
        </div>
        <form method="post" id="addonForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="addonId" />
            <input type="hidden" name="activeTab" value="addons" />
            <div class="cafe-modal-body">

                <div class="form-group">
                    <label class="form-label">Name *</label>
                    <input class="form-control-cafe" name="Name" id="addonName"
                           required placeholder="e.g., Extra Shot" />
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <input class="form-control-cafe" name="Category" id="addonCategory"
                           placeholder="e.g., Toppings" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Price (₱) *</label>
                        <input class="form-control-cafe" type="number" name="Price"
