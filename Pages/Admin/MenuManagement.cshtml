@section Scripts {
<script>

    // ── Tab switching ──────────────────────────────────────────────────────────
    function switchTab(tab) {
        document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
        document.querySelectorAll('.mm-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('panel-' + tab).style.display = 'block';
        // Match tab button by its text content slug
        document.querySelectorAll('.mm-tab').forEach(t => {
            const slug = t.textContent.trim().toLowerCase().replace(/[^a-z]/g, '');
            if (slug.startsWith(tab.replace(/[^a-z]/g, '').substring(0, 4)))
                t.classList.add('active');
        });
        document.getElementById('activeTabInput').value = tab;
    }

    // ── Item search / filter ───────────────────────────────────────────────────
    function filterItems() {
        const q   = document.getElementById('itemSearch').value.toLowerCase();
        const cat = document.getElementById('catFilter').value.toLowerCase();
        document.querySelectorAll('#itemsGrid .item-card').forEach(card => {
            const name = card.dataset.name || '';
            const c    = (card.dataset.cat || '').toLowerCase();
            card.style.display =
                (!q || name.includes(q)) && (!cat || c === cat) ? '' : 'none';
        });
    }

    // ── SINGLE closeModals (fixes duplicate declaration bug) ───────────────────
    function closeModals() {
        [
            'itemModalBackdrop',
            'categoryModalBackdrop',
            'customizationModalBackdrop',
            'addonModalBackdrop',
            'pricingModalBackdrop',
            'assignModalBackdrop'
        ].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.style.display = 'none';
        });
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModals(); });

    // ── Image preview ──────────────────────────────────────────────────────────
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                const preview = document.getElementById('itemImagePreview');
                preview.src = e.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    // ── Item modal ─────────────────────────────────────────────────────────────
    function openAddItemModal() {
        document.getElementById('itemModalTitle').textContent = 'Add New Item';
        document.getElementById('itemForm').action = '@Url.Page("MenuManagement", "SaveItem")';
        document.getElementById('itemId').value            = '';
        document.getElementById('itemName').value          = '';
        document.getElementById('itemCategoryId').value    = '';
        document.getElementById('itemPrice').value         = '';
        document.getElementById('itemCost').value          = '0';
        document.getElementById('itemDescription').value   = '';
        document.getElementById('itemPrepTime').value      = '5';
        document.getElementById('itemIsAvailable').checked = true;
        document.getElementById('itemAvailFrom').value     = '06:00';
        document.getElementById('itemAvailUntil').value    = '22:00';
        document.getElementById('itemImagePreview').style.display = 'none';
        document.getElementById('itemExistingImage').value = '';
        document.getElementById('itemExistingMime').value  = '';
        document.getElementById('itemImageFile').value     = '';
        document.getElementById('itemModalBackdrop').style.display = 'flex';
    }

    function openEditItemModal(id, name, categoryId, desc, price, cost, prepTime, isAvail, from, until, imgB64, imgMime) {
        document.getElementById('itemModalTitle').textContent = 'Edit Item';
        document.getElementById('itemForm').action = '@Url.Page("MenuManagement", "SaveItem")';
        document.getElementById('itemId').value            = id;
        document.getElementById('itemName').value          = name;
        document.getElementById('itemCategoryId').value    = categoryId;
        document.getElementById('itemDescription').value   = desc;
        document.getElementById('itemPrice').value         = price;
        document.getElementById('itemCost').value          = cost;
        document.getElementById('itemPrepTime').value      = prepTime;
        document.getElementById('itemIsAvailable').checked = isAvail === 'true';
        document.getElementById('itemAvailFrom').value     = from;
        document.getElementById('itemAvailUntil').value    = until;
        document.getElementById('itemExistingImage').value = imgB64  || '';
        document.getElementById('itemExistingMime').value  = imgMime || '';
        document.getElementById('itemImageFile').value     = '';
        const preview = document.getElementById('itemImagePreview');
        if (imgB64) {
            preview.src = 'data:' + imgMime + ';base64,' + imgB64;
            preview.style.display = 'block';
        } else {
            preview.style.display = 'none';
        }
        document.getElementById('itemModalBackdrop').style.display = 'flex';
    }

    // ── Assign modal ───────────────────────────────────────────────────────────
    // assignedCustIds and assignedAddonIds are plain JS arrays passed from Razor.
    // The checkbox data-id attributes match the GUID strings from the server.
    function openAssignModal(itemId, itemName, assignedCustIds, assignedAddonIds) {
        document.getElementById('assignModalTitle').textContent = 'Assign Options — ' + itemName;
        document.getElementById('assignItemId').value = itemId;

        // Always reset then re-check so repeated opens reflect current assignments
        document.querySelectorAll('.cust-cb').forEach(cb => {
            cb.checked = assignedCustIds.includes(cb.dataset.id);
            // Visually highlight the parent label
            cb.closest('label').classList.toggle('assign-item-checked', cb.checked);
        });
        document.querySelectorAll('.addon-cb').forEach(cb => {
            cb.checked = assignedAddonIds.includes(cb.dataset.id);
            cb.closest('label').classList.toggle('assign-item-checked', cb.checked);
        });

        document.getElementById('assignModalBackdrop').style.display = 'flex';
    }

    // Live highlight as user checks/unchecks inside the assign modal
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('assign-checkbox')) {
            e.target.closest('label').classList.toggle('assign-item-checked', e.target.checked);
        }
    });

    // ── Category modal ─────────────────────────────────────────────────────────
    function openAddCategoryModal() {
        document.getElementById('categoryModalTitle').textContent = 'Add Category';
        document.getElementById('categoryForm').action = '@Url.Page("MenuManagement", "SaveCategory")';
        document.getElementById('catId').value      = '';
        document.getElementById('catName').value    = '';
        document.getElementById('catDesc').value    = '';
        document.getElementById('catColor').value   = '#8B4513';
        document.getElementById('catOrder').value   = '0';
        document.getElementById('catIsActive').checked = true;
        document.getElementById('categoryModalBackdrop').style.display = 'flex';
    }

    function openEditCategoryModal(id, name, desc, color, order, isActive) {
        document.getElementById('categoryModalTitle').textContent = 'Edit Category';
        document.getElementById('categoryForm').action = '@Url.Page("MenuManagement", "SaveCategory")';
        document.getElementById('catId').value      = id;
        document.getElementById('catName').value    = name;
        document.getElementById('catDesc').value    = desc;
        document.getElementById('catColor').value   = color;
        document.getElementById('catOrder').value   = order;
        document.getElementById('catIsActive').checked = isActive === 'true';
        document.getElementById('categoryModalBackdrop').style.display = 'flex';
    }

    // ── Customization modal ────────────────────────────────────────────────────
    // optionIndex tracks the form array index; reset on every modal open.
    let optionIndex = 0;

        function openAddCustomizationModal() {
            document.getElementById('custModalTitle').textContent = 'Add Customization';
            document.getElementById('custForm').action = '@Url.Page("MenuManagement", "SaveCustomization")';
            document.getElementById('custId').value           = '';
            document.getElementById('custName').value         = '';
            document.getElementById('custType').value         = 'Radio';
            document.getElementById('custIsRequired').checked = false;
            document.getElementById('custOptionsContainer').innerHTML = '';
            optionIndex = 0;
            // Label for adding
            document.getElementById('custSaveBtnLabel').textContent = 'Save Customization';
            document.getElementById('customizationModalBackdrop').style.display = 'flex';
        }

        function openEditCustomizationModal(cust) {
            document.getElementById('custModalTitle').textContent = 'Edit Customization';
            document.getElementById('custForm').action = '@Url.Page("MenuManagement", "SaveCustomization")';
            document.getElementById('custId').value           = cust.id;
            document.getElementById('custName').value         = cust.name;
            document.getElementById('custType').value         = cust.type;
            document.getElementById('custIsRequired').checked = cust.isRequired;
            const container = document.getElementById('custOptionsContainer');
            container.innerHTML = '';
            optionIndex = 0;
            (cust.options || []).forEach(opt => addCustOptionRow(opt));
            // Label for editing
            document.getElementById('custSaveBtnLabel').textContent = 'Save Changes';
            document.getElementById('customizationModalBackdrop').style.display = 'flex';
        }

    function addCustOption() {
        addCustOptionRow(null);
    }

    // Each row: label, price modifier (always visible), default toggle, remove
    function addCustOptionRow(opt) {
        const idx       = optionIndex++;
        const container = document.getElementById('custOptionsContainer');
        const div       = document.createElement('div');
        div.className   = 'opt-edit-row';

        // Use opt.optionLabel (C# serializes OptionLabel → optionLabel)
        const label         = opt?.optionLabel ?? opt?.label ?? '';
        const priceModifier = opt?.priceModifier ?? 0;
        const isDefault     = opt?.isDefault     ?? false;
        const existingId    = opt?.id            ?? '';

        div.innerHTML = `
            <input type="hidden"
                   name="Options[${idx}].Id"
                   value="${existingId}" />

            <input class="form-control-cafe"
                   name="Options[${idx}].OptionLabel"
                   placeholder="Option label (e.g. Large)"
                   value="${escHtml(label)}"
                   required />

            <div class="opt-price-wrap">
                <span class="opt-price-prefix">+₱</span>
                <input class="form-control-cafe short"
                       type="number"
                       step="0.01"
                       min="0"
                       name="Options[${idx}].PriceModifier"
                       placeholder="0.00"
                       value="${parseFloat(priceModifier).toFixed(2)}" />
            </div>

            <label class="toggle-switch" style="gap:6px;white-space:nowrap;font-size:12px;cursor:pointer">
                <input type="checkbox"
                       name="Options[${idx}].IsDefault"
                       value="true"
                       ${isDefault ? 'checked' : ''} />
                <span class="toggle-track"></span>
                <span>Default</span>
            </label>

            <button type="button" class="opt-remove" title="Remove option"
                    onclick="this.closest('.opt-edit-row').remove()">×</button>`;

        container.appendChild(div);
    }

    // ── Add-on modal ───────────────────────────────────────────────────────────
    function openAddAddonModal() {
        document.getElementById('addonModalTitle').textContent = 'Add Add-on';
        document.getElementById('addonForm').action = '@Url.Page("MenuManagement", "SaveAddon")';
        document.getElementById('addonId').value       = '';
        document.getElementById('addonName').value     = '';
        document.getElementById('addonCategory').value = '';
        document.getElementById('addonPrice').value    = '';
        document.getElementById('addonIsActive').checked = true;
        document.getElementById('addonModalBackdrop').style.display = 'flex';
    }

    function openEditAddonModal(id, name, category, price, isActive) {
        document.getElementById('addonModalTitle').textContent = 'Edit Add-on';
        document.getElementById('addonForm').action = '@Url.Page("MenuManagement", "SaveAddon")';
        document.getElementById('addonId').value       = id;
        document.getElementById('addonName').value     = name;
        document.getElementById('addonCategory').value = category;
        document.getElementById('addonPrice').value    = price;
        document.getElementById('addonIsActive').checked = isActive === 'true';
        document.getElementById('addonModalBackdrop').style.display = 'flex';
    }

    // ── Pricing modal ──────────────────────────────────────────────────────────
    function openPricingModal(id, name, price, cost) {
        document.getElementById('pricingModalTitle').textContent = 'Update Pricing — ' + name;
        document.getElementById('pricingId').value    = id;
        document.getElementById('pricingPrice').value = price;
        document.getElementById('pricingCost').value  = cost;
        updateMarginPreview();
        document.getElementById('pricingModalBackdrop').style.display = 'flex';
    }

    function updateMarginPreview() {
        const price  = parseFloat(document.getElementById('pricingPrice').value) || 0;
        const cost   = parseFloat(document.getElementById('pricingCost').value)  || 0;
        const margin = price > 0 ? ((price - cost) / price * 100).toFixed(1) : '0.0';
        const profit = (price - cost).toFixed(2);
        document.getElementById('marginPreview').textContent = margin + '%';
        const pp = document.getElementById('profitPreview');
        if (pp) pp.textContent = '₱' + profit;
    }

    // ── Utility: escape HTML to prevent XSS in innerHTML assignments ───────────
    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/"/g, '&quot;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
    }

    // ── Auto-dismiss success banner ────────────────────────────────────────────
    const sb = document.getElementById('successBanner');
    if (sb) setTimeout(() => sb.remove(), 3000);

</script>
}