@page
@model AccountManagementModel

@{
    ViewData["Title"] = "Account Management";
    ViewData["Subtitle"] = "Manage staff accounts and permissions";
}

@section TopbarActions {
    <button class="btn-ghost-cafe">
        <i class="ti ti-download" aria-hidden="true"></i> Export
    </button>
    <button class="btn-primary-cafe" data-bs-toggle="modal" data-bs-target="#addAccountModal">
        <i class="ti ti-plus" aria-hidden="true"></i> Add Account
    </button>
}

<!-- ── Stat Cards ───────────────────────────────────────────── -->
<div class="stats-row">

    <div class="stat-card">
        <div class="stat-card-label">
            <i class="ti ti-users" aria-hidden="true"></i> Total Accounts
        </div>
        <div class="stat-card-value">@Model.TotalAccounts</div>
        <div class="stat-card-sub">
            <span class="text-success">↑ 2 this month</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-label">
            <i class="ti ti-circle-check" aria-hidden="true"></i> Active
        </div>
        <div class="stat-card-value">@Model.ActiveCount</div>
        <div class="stat-card-sub">
            @(Model.TotalAccounts > 0
                ? $"{(Model.ActiveCount * 100.0 / Model.TotalAccounts):F1}% of total"
                : "No accounts yet")
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-label">
            <i class="ti ti-shield" aria-hidden="true"></i> Admins
        </div>
        <div class="stat-card-value">@Model.AdminCount</div>
        <div class="stat-card-sub">Full access</div>
    </div>

    <div class="stat-card">
        <div class="stat-card-label">
            <i class="ti ti-circle-x" aria-hidden="true"></i> Inactive
        </div>
        <div class="stat-card-value">@Model.InactiveCount</div>
        <div class="stat-card-sub">
            <span class="text-danger">Requires attention</span>
        </div>
    </div>

</div>

<!-- ── Accounts Table ────────────────────────────────────────── -->
<div class="table-card">

    <div class="table-card-header">
        <div class="table-card-title">
            Staff Accounts <span>@Model.TotalAccounts total</span>
        </div>
        <div class="table-tools">
            <div class="search-box">
                <i class="ti ti-search" aria-hidden="true"></i>
                <input type="text" placeholder="Search accounts…" id="searchInput" />
            </div>
            <select class="filter-select" id="roleFilter">
                <option value="">All Roles</option>
                @foreach (var role in Model.Roles)
                {
                    <option value="@role.RoleName">@role.RoleName</option>
                }
            </select>
            <select class="filter-select" id="statusFilter">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Staff Member</th>
                <th>Role</th>
                <th>Date Created</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>

            @if (!Model.Users.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center;padding:32px;color:var(--text-mute);">
                        <i class="ti ti-users-off" style="font-size:24px;display:block;margin-bottom:8px;"></i>
                        No accounts found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var user in Model.Users)
                {
                    var nameParts = user.FullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    var initials = nameParts.Length >= 2
                        ? $"{nameParts[0][0]}{nameParts[^1][0]}"
                        : user.FullName.Length >= 2
                            ? user.FullName[..2]
                            : user.FullName;

                    var roleName = user.Role?.RoleName ?? "—";
                    var roleClass = roleName.ToLower() switch
                    {
                        "admin" => "role-admin",
                        "manager" => "role-manager",
                        "cashier" => "role-cashier",
                        _ => "role-cashier"
                    };

                    var avatarColors = new[] { "av-brown", "av-green", "av-amber", "av-red", "av-purple" };
                    var avatarClass = avatarColors[Math.Abs(user.UserId.GetHashCode()) % avatarColors.Length];

                    var statusLabel = user.IsActive ? "Active" : "Inactive";
                    var dotClass = user.IsActive ? "dot-active" : "dot-inactive";
                    var createdAt = user.CreatedAt.HasValue
                        ? user.CreatedAt.Value.ToString("MMM dd, yyyy")
                        : "—";

                    <tr>
                        <td>
                            <div class="avatar-cell">
                                <div class="av @avatarClass">@initials.ToUpper()</div>
                                <div>
                                    <div class="av-name">@user.FullName</div>
                                    <div class="av-email">@user.Username</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="role-badge @roleClass">@roleName</span>
                        </td>
                        <td style="color:var(--text-mute);font-size:13px">@createdAt</td>
                        <td>
                            <span class="status-dot">
                                <span class="dot @dotClass"></span> @statusLabel
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="icon-btn"
                                        title="Edit account"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editAccountModal"
                                        data-userid="@user.UserId"
                                        data-fullname="@user.FullName"
                                        data-username="@user.Username"
                                        data-roleid="@user.RoleId"
                                        data-isactive="@user.IsActive.ToString().ToLower()">
                                    <i class="ti ti-edit" aria-hidden="true"></i>
                                </button>
                                <button class="icon-btn" title="View account"
                                        data-bs-toggle="modal"
                                        data-bs-target="#viewAccountModal"
                                        data-userid="@user.UserId"
                                        data-fullname="@user.FullName"
                                        data-username="@user.Username"
                                        data-role="@roleName"
                                        data-status="@statusLabel"
                                        data-created="@createdAt">
                                    <i class="ti ti-eye" aria-hidden="true"></i>
                                </button>
                                <button class="icon-btn icon-btn-danger"
                                        title="Delete account"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteConfirmModal"
                                        data-userid="@user.UserId"
                                        data-fullname="@user.FullName">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }

        </tbody>
    </table>

    <div class="pagination-bar">
        <p class="pagination-info">
            Showing @Model.PageStart–@Model.PageEnd of @Model.TotalAccounts accounts
        </p>
        <div class="pagination-btns">
            <a asp-page="./AccountManagement"
               asp-route-page="@(Model.CurrentPage - 1)"
               class="pg-btn @(Model.CurrentPage <= 1 ? "disabled" : "")"
               aria-label="Previous page">
                <i class="ti ti-chevron-left" aria-hidden="true"></i>
            </a>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-page="./AccountManagement"
                   asp-route-page="@i"
                   class="pg-btn @(i == Model.CurrentPage ? "pg-btn-active" : "")">@i</a>
            }

            <a asp-page="./AccountManagement"
               asp-route-page="@(Model.CurrentPage + 1)"
               class="pg-btn @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")"
               aria-label="Next page">
                <i class="ti ti-chevron-right" aria-hidden="true"></i>
            </a>
        </div>
    </div>

</div>


<!-- ── Add Account Modal ─────────────────────────────────────── -->
<div class="modal fade" id="addAccountModal" tabindex="-1" aria-labelledby="addAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="addAccountModalLabel">
                    <i class="ti ti-user-plus" aria-hidden="true" style="margin-right:6px;color:var(--brown)"></i>
                    Add New Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="Add">
                @Html.AntiForgeryToken()
                <div class="modal-body">

                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="FullName" class="form-control-cafe"
                               placeholder="e.g. Juan dela Cruz" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <input type="text" name="Username" class="form-control-cafe"
                               placeholder="e.g. j.delacruz" required />
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                        <div class="form-group">
                            <label class="form-label">Role</label>
                            <select name="RoleId" class="form-control-cafe" required>
                                <option value="">Select role…</option>
                                @foreach (var role in Model.Roles)
                                {
                                    <option value="@role.RoleId">@role.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select name="IsActive" class="form-control-cafe">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input type="password" name="Password" class="form-control-cafe"
                               placeholder="Minimum 8 characters" required minlength="8" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" class="form-control-cafe"
                               placeholder="Re-enter password" required minlength="8" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.AddError))
                    {
                        <div class="alert alert-danger mt-2" style="font-size:13px;">
                            <i class="ti ti-alert-circle"></i> @Model.AddError
                        </div>
                    }

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-ghost-cafe" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-cafe">
                        <i class="ti ti-check" aria-hidden="true"></i> Create Account
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>


<!-- ── Edit Account Modal ────────────────────────────────────── -->
<div class="modal fade" id="editAccountModal" tabindex="-1" aria-labelledby="editAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="editAccountModalLabel">
                    <i class="ti ti-edit" aria-hidden="true" style="margin-right:6px;color:var(--brown)"></i>
                    Edit Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="Edit">
                @Html.AntiForgeryToken()
                <div class="modal-body">

                    <input type="hidden" name="UserId" id="editUserId" />

                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="FullName" id="editFullName"
                               class="form-control-cafe" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <input type="text" name="Username" id="editUsername"
                               class="form-control-cafe" required />
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                        <div class="form-group">
                            <label class="form-label">Role</label>
                            <select name="RoleId" id="editRoleId" class="form-control-cafe" required>
                                @foreach (var role in Model.Roles)
                                {
                                    <option value="@role.RoleId">@role.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select name="IsActive" id="editIsActive" class="form-control-cafe">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">New Password <small style="color:var(--text-mute)">(leave blank to keep current)</small></label>
                        <input type="password" name="Password" class="form-control-cafe"
                               placeholder="Minimum 8 characters" minlength="8" />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-ghost-cafe" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-cafe">
                        <i class="ti ti-check" aria-hidden="true"></i> Save Changes
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>


<!-- ── View Account Modal ────────────────────────────────────── -->
<div class="modal fade" id="viewAccountModal" tabindex="-1" aria-labelledby="viewAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="viewAccountModalLabel">
                    <i class="ti ti-user" aria-hidden="true" style="margin-right:6px;color:var(--brown)"></i>
                    Account Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <table style="width:100%;font-size:14px;border-collapse:collapse;">
                    <tr>
                        <td style="padding:8px 0;color:var(--text-mute);width:40%">Full Name</td>
                        <td id="viewFullName" style="padding:8px 0;font-weight:500"></td>
                    </tr>
                    <tr>
                        <td style="padding:8px 0;color:var(--text-mute)">Username</td>
                        <td id="viewUsername" style="padding:8px 0"></td>
                    </tr>
                    <tr>
                        <td style="padding:8px 0;color:var(--text-mute)">Role</td>
                        <td id="viewRole" style="padding:8px 0"></td>
                    </tr>
                    <tr>
                        <td style="padding:8px 0;color:var(--text-mute)">Status</td>
                        <td id="viewStatus" style="padding:8px 0"></td>
                    </tr>
                    <tr>
                        <td style="padding:8px 0;color:var(--text-mute)">Date Created</td>
                        <td id="viewCreated" style="padding:8px 0"></td>
                    </tr>
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost-cafe" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>


<!-- ── Delete Confirm Modal ──────────────────────────────────── -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="deleteConfirmModalLabel" style="color:var(--danger)">
                    <i class="ti ti-alert-triangle" aria-hidden="true" style="margin-right:6px"></i>
                    Delete Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body" style="font-size:14px;">
                Are you sure you want to delete <strong id="deleteFullName"></strong>?
                This action cannot be undone.
            </div>

            <form method="post" asp-page-handler="Delete">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" id="deleteUserId" />
                <div class="modal-footer">
                    <button type="button" class="btn-ghost-cafe" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-cafe" style="background:var(--danger)">
                        <i class="ti ti-trash" aria-hidden="true"></i> Delete
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>


@section Scripts {
    <script>
        // ── Live search + filter ────────────────────────────────
        document.getElementById('searchInput').addEventListener('input', filterTable);
        document.getElementById('roleFilter').addEventListener('change', filterTable);
        document.getElementById('statusFilter').addEventListener('change', filterTable);

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const role   = document.getElementById('roleFilter').value.toLowerCase();
            const status = document.getElementById('statusFilter').value.toLowerCase();
            const rows   = document.querySelectorAll('.data-table tbody tr');

            rows.forEach(row => {
                const name   = row.querySelector('.av-name')?.textContent.toLowerCase()  || '';
                const email  = row.querySelector('.av-email')?.textContent.toLowerCase() || '';
                const badge  = row.querySelector('.role-badge')?.textContent.toLowerCase() || '';
                const dot    = row.querySelector('.status-dot')?.textContent.trim().toLowerCase() || '';

                const matchSearch = !search || name.includes(search) || email.includes(search);
                const matchRole   = !role   || badge.includes(role);
                const matchStatus = !status || dot.includes(status);

                row.style.display = (matchSearch && matchRole && matchStatus) ? '' : 'none';
            });
        }

        // ── Edit modal – pre-fill fields ────────────────────────
        document.getElementById('editAccountModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('editUserId').value   = btn.dataset.userid;
            document.getElementById('editFullName').value = btn.dataset.fullname;
            document.getElementById('editUsername').value = btn.dataset.username;
            document.getElementById('editRoleId').value   = btn.dataset.roleid;
            document.getElementById('editIsActive').value = btn.dataset.isactive;
        });

        // ── View modal – populate details ───────────────────────
        document.getElementById('viewAccountModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('viewFullName').textContent = btn.dataset.fullname;
            document.getElementById('viewUsername').textContent = btn.dataset.username;
            document.getElementById('viewRole').textContent     = btn.dataset.role;
            document.getElementById('viewStatus').textContent   = btn.dataset.status;
            document.getElementById('viewCreated').textContent  = btn.dataset.created;
        });

        // ── Delete modal – populate name & id ───────────────────
        document.getElementById('deleteConfirmModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteUserId').value        = btn.dataset.userid;
            document.getElementById('deleteFullName').textContent = btn.dataset.fullname;
        });

        // ── Re-open Add modal on validation error ───────────────
        @if (!string.IsNullOrEmpty(Model.AddError))
        {
                <text>
                    var addModal = new bootstrap.Modal(document.getElementById('addAccountModal'));
                    addModal.show();
                </text>
        }
    </script>
}
