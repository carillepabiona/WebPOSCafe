@page
@model IndexModel
@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/layout.css" />

<div class="login-container">
    <div class="login-wrapper">
        <div class="login-form-wrapper">

            <!-- Left: Brand Panel -->
            <div class="login-accent-panel">
                <div class="login-logo-ring">
                    <span class="login-logo-letter">V</span>
                </div>
                <div class="login-brand">
                    <h1>VERSO</h1>
                    <p>Cafe &amp; Co.</p>
                </div>
                <div class="login-divider"></div>
                <p class="login-tagline">Every cup tells a story worth savoring.</p>
            </div>

            <!-- Right: Form Panel -->
            <div class="login-fields">
                <div class="login-header">
                    <h2>Welcome back</h2>
                    <p>Sign in to your workspace</p>
                </div>

                <div id="error-message" class="alert-error" style="display:none;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <span id="error-text"></span>
                </div>

                <div class="form-group">
                    <label for="username">Username</label>
                    <div class="input-icon-wrapper">
                        <input type="text" id="username" placeholder="Enter your username"
                               class="form-input" autocomplete="username" />
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-icon-wrapper">
                        <input type="password" id="password" placeholder="Enter your password"
                               class="form-input has-toggle" autocomplete="current-password" />
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <button type="button" class="password-toggle" onclick="togglePassword()" aria-label="Show password">
                            <svg id="icon-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                            <svg id="icon-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                                <line x1="1" y1="1" x2="23" y2="23"></line>
                            </svg>
                        </button>
                    </div>
                </div>

                <button class="btn-login" id="login-btn" onclick="login()">
                    <span id="btn-text">Sign In</span>
                    <span id="btn-spinner" class="spinner" style="display:none;"></span>
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById("password");
        const isHidden = input.type === "password";
        input.type = isHidden ? "text" : "password";
        document.getElementById("icon-show").style.display = isHidden ? "none" : "";
        document.getElementById("icon-hide").style.display = isHidden ? "" : "none";
        this.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
    }

    function fillRole(username, password) {
        document.getElementById("username").value = username;
        document.getElementById("password").value = password;
        document.getElementById("error-message").style.display = "none";
    }

    function login() {
        const username = document.getElementById("username").value.trim();
        const password = document.getElementById("password").value.trim();
        const errorBox = document.getElementById("error-message");
        const errorTxt = document.getElementById("error-text");

        if (!username || !password) {
            errorTxt.textContent = "Please enter your username and password.";
            errorBox.style.display = "flex";
            return;
        }

        errorBox.style.display = "none";
        document.getElementById("login-btn").disabled = true;
        document.getElementById("btn-text").textContent = "Signing in...";
        document.getElementById("btn-spinner").style.display = "inline-block";

        // ── Hardcoded credentials — replace with a real API call later ──
        setTimeout(() => {
            if (username === "admin" && password === "admin123") {
                window.location.href = "/Admin/AccountManagement";
            } else if (username === "cashier" && password === "cashier123") {
                window.location.href = "/Cashier/Dashboard";
            } else {
                errorTxt.textContent = "Invalid username or password.";
                errorBox.style.display = "flex";
                document.getElementById("login-btn").disabled = false;
                document.getElementById("btn-text").textContent = "Sign In";
                document.getElementById("btn-spinner").style.display = "none";
            }
        }, 700);
    }

    document.addEventListener("keydown", function (e) {
        if (e.key === "Enter") login();
    });
</script>
