@page
@model WebPOSCafe.Pages.KDS.KitchenDisplayModel

@{
    ViewData["Title"] = "Kitchen Display";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KDS — Verso Kitchen</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/kds.css" />
</head>
<body>

    <!-- ── TOP BAR ── -->
    <div class="kds-topbar">
        <div class="kds-brand">
            <span class="kds-brand-dot"></span>
            VERSO KDS
        </div>

        <div class="kds-stats">
            <div class="kds-stat s-pending">
                <span>NEW</span>
                <span class="kds-stat-val" id="stat-pending">0</span>
            </div>
            <div class="kds-stat s-prep">
                <span>COOKING</span>
                <span class="kds-stat-val" id="stat-preparing">0</span>
            </div>
            <div class="kds-stat s-ready">
                <span>READY</span>
                <span class="kds-stat-val" id="stat-ready">0</span>
            </div>
        </div>

        <div style="display:flex;align-items:center;gap:10px">
            <button class="sound-btn" id="sound-btn" onclick="toggleSound()">🔔 Sound ON</button>
            <span class="kds-clock" id="clock">--:--:--</span>
        </div>
    </div>

    <!-- ── COLUMNS ── -->
    <div class="kds-body">

        <!-- PENDING -->
        <div class="kds-col col-pending">
            <div class="kds-col-header">
                <div class="col-title">
                    <span class="col-dot"></span>
                    NEW ORDERS
                </div>
                <span class="col-count" id="count-pending">0</span>
            </div>
            <div class="kds-col-body" id="col-pending"></div>
        </div>

        <!-- PREPARING -->
        <div class="kds-col col-preparing">
            <div class="kds-col-header">
                <div class="col-title">
                    <span class="col-dot"></span>
                    PREPARING
                </div>
                <span class="col-count" id="count-preparing">0</span>
            </div>
            <div class="kds-col-body" id="col-preparing"></div>
        </div>

        <!-- READY -->
        <div class="kds-col col-ready">
            <div class="kds-col-header">
                <div class="col-title">
                    <span class="col-dot"></span>
                    READY
                </div>
                <span class="col-count" id="count-ready">0</span>
            </div>
            <div class="kds-col-body" id="col-ready"></div>
        </div>

    </div>

    <!-- ── RECALL BAR ── -->
    <div class="recall-bar" id="recall-bar">
        <span class="recall-label">Bumped</span>
        <span style="color:var(--text-dim);font-size:0.72rem">Recently served orders appear here</span>
        <div id="recall-list" style="display:flex;gap:6px;flex-wrap:wrap"></div>
    </div>

    <script>
            // ── CONFIG ──────────────────────────────────────────────────────────────
            const POLL_INTERVAL = 5000;
            let soundEnabled  = true;
            let knownOrderIds = new Set();
            let bumpedOrders  = [];
            let checkedItems  = {};   // orderId -> Set of item indices

            // ── CLOCK ───────────────────────────────────────────────────────────────
            function updateClock() {
                const now = new Date();
                document.getElementById('clock').textContent =
                    now.toLocaleTimeString('en-PH', { hour12: false });
            }
            setInterval(updateClock, 1000);
            updateClock();

            // ── SOUND ───────────────────────────────────────────────────────────────
            function toggleSound() {
                soundEnabled = !soundEnabled;
                document.getElementById('sound-btn').textContent =
                    soundEnabled ? '🔔 Sound ON' : '🔕 Sound OFF';
            }

            function playChime() {
                if (!soundEnabled) return;
                try {
                    const ctx = new (window.AudioContext || window.webkitAudioContext)();
                    [523, 659, 784].forEach((freq, i) => {
                        const osc  = ctx.createOscillator();
                        const gain = ctx.createGain();
                        osc.connect(gain);
                        gain.connect(ctx.destination);
                        osc.frequency.value = freq;
                        osc.type = 'sine';
                        const t = ctx.currentTime + i * 0.18;
                        gain.gain.setValueAtTime(0.3, t);
                        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.4);
                        osc.start(t);
                        osc.stop(t + 0.4);
                    });
                } catch(e) {}
            }

            // ── RENDER CARD ──────────────────────────────────────────────────────────
            function renderCard(order) {
                const checked = checkedItems[order.id] || new Set();

                const itemsHtml = order.items.map((item, idx) => {
                    const done = checked.has(idx);
                    return `
                    <div class="kds-item${done ? ' done' : ''}" id="item-${order.id}-${idx}">
                        <input type="checkbox" class="kds-item-check"
                               ${done ? 'checked' : ''}
                               onchange="toggleItem(${order.id}, ${idx}, this)" />
                        <div class="kds-item-info">
                            <div class="kds-item-name">${item.quantity}× ${item.name}</div>
                            ${item.customization       ? `<div class="kds-item-mods">${item.customization}</div>` : ''}
                            ${item.specialInstructions ? `<div class="kds-item-note">📝 ${item.specialInstructions}</div>` : ''}
                        </div>
                    </div>`;
                }).join('');

                // ── ACTION BUTTON per status ──────────────────────────────────────────
                let actionBtn = '';
                if (order.status === 'pending') {
                    actionBtn = `<button class="kds-btn kds-btn-start" onclick="updateStatus(${order.id}, 'preparing')">▶ Start</button>`;
                } else if (order.status === 'preparing') {
                    actionBtn = `<button class="kds-btn kds-btn-ready" onclick="updateStatus(${order.id}, 'ready')">✓ Ready</button>`;
                } else if (order.status === 'ready') {
                    // ── THIS IS THE FIX: "Done" now calls markServed() ────────────────
                    actionBtn = `<button class="kds-btn kds-btn-done" onclick="markServed(${order.id})">✔ Done — Served</button>`;
                }

                const tableDisplay = order.tableNumber
                    ? `<span class="kds-table-badge">T-${order.tableNumber}</span>`
                    : `<span class="kds-type-badge take-out">Takeout</span>`;

                return `
                <div class="kds-card status-${order.status}" id="card-${order.id}">
                    <div class="kds-card-head">
                        <span class="kds-order-num">${order.orderNumber}</span>
                        ${tableDisplay}
                        <span class="kds-type-badge ${order.type}">${order.type === 'dine-in' ? 'Dine-In' : 'Takeout'}</span>
                    </div>
                    ${order.customerName ? `<div class="kds-customer">👤 ${order.customerName}</div>` : ''}
                    <div class="kds-items">${itemsHtml}</div>
                    <div class="kds-card-actions">
                        ${actionBtn}
                        <button class="kds-btn kds-btn-bump" title="Bump order" onclick="bumpOrder(${order.id})">✕</button>
                    </div>
                </div>`;
            }

            // ── RENDER ALL COLUMNS ────────────────────────────────────────────────────
            function renderAll(orders) {
                const pending   = orders.filter(o => o.status === 'pending');
                const preparing = orders.filter(o => o.status === 'preparing');
                const ready     = orders.filter(o => o.status === 'ready');

                document.getElementById('count-pending').textContent   = pending.length;
                document.getElementById('count-preparing').textContent = preparing.length;
                document.getElementById('count-ready').textContent     = ready.length;
                document.getElementById('stat-pending').textContent    = pending.length;
                document.getElementById('stat-preparing').textContent  = preparing.length;
                document.getElementById('stat-ready').textContent      = ready.length;

                const empty = () => `<div class="kds-empty"><div class="kds-empty-icon">—</div><div>No orders</div></div>`;

                document.getElementById('col-pending').innerHTML =
                    pending.length   ? pending.map(renderCard).join('')   : empty();
                document.getElementById('col-preparing').innerHTML =
                    preparing.length ? preparing.map(renderCard).join('') : empty();
                document.getElementById('col-ready').innerHTML =
                    ready.length     ? ready.map(renderCard).join('')     : empty();
            }

            // ── STATE ─────────────────────────────────────────────────────────────────
            let currentOrders = [];

            // ── FETCH ORDERS FROM SERVER ──────────────────────────────────────────────
            async function fetchOrders() {
                try {
                    const res = await fetch('/api/kds/orders');
                    if (!res.ok) return;
                    const data = await res.json();

                    // Chime on genuinely new pending orders
                    const newIds = data.filter(o => o.status === 'pending').map(o => o.id);
                    const hasNew = newIds.some(id => !knownOrderIds.has(id));
                    if (hasNew && knownOrderIds.size > 0) playChime();
                    newIds.forEach(id => knownOrderIds.add(id));

                    currentOrders = data;
                    renderAll(data);
                } catch(e) {
                    console.error('KDS fetch error:', e);
                }
            }

            // ── UPDATE STATUS (pending → preparing → ready) ───────────────────────────
            async function updateStatus(orderId, newStatus) {
                try {
                    await fetch('/api/kds/status', {
                        method:  'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body:    JSON.stringify({ orderId, newStatus })
                    });
                    await fetchOrders();
                } catch(e) {
                    console.error('Status update failed:', e);
                }
            }

            // ── MARK SERVED (ready → served) ──────────────────────────────────────────
            // Called by the "✔ Done — Served" button on ready cards.
            // Sends status "served" to the server, then animates the card out.
            async function markServed(orderId) {
                const order = currentOrders.find(o => o.id === orderId);
                if (!order) return;

                try {
                    await fetch('/api/kds/status', {
                        method:  'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body:    JSON.stringify({ orderId, newStatus: 'served' })
                    });
                } catch(e) {
                    console.error('Mark served failed:', e);
                }

                // Add to recall bar (last 5)
                bumpedOrders.unshift(order);
                if (bumpedOrders.length > 5) bumpedOrders.pop();

                document.getElementById('recall-list').innerHTML = bumpedOrders.map(o => `
                    <div class="recall-item" onclick="recallOrder(${o.id})" title="Recall #${o.orderNumber}">
                        <span class="recall-num">${o.orderNumber}</span>
                        <span>${o.tableNumber ? 'T-' + o.tableNumber : 'Takeout'}</span>
                    </div>`).join('');

                // Animate card out
                const card = document.getElementById(`card-${orderId}`);
                if (card) {
                    card.style.transition = 'opacity 0.2s, transform 0.2s';
                    card.style.opacity    = '0';
                    card.style.transform  = 'scale(0.95)';
                    setTimeout(() => {
                        currentOrders = currentOrders.filter(o => o.id !== orderId);
                        renderAll(currentOrders);
                    }, 200);
                } else {
                    currentOrders = currentOrders.filter(o => o.id !== orderId);
                    renderAll(currentOrders);
                }
            }

            // ── BUMP ORDER (force-remove from KDS without marking served) ────────────
            // Use this to dismiss an order from view without changing its status.
            // The next poll will bring it back if it's still active on the server.
            async function bumpOrder(orderId) {
                const order = currentOrders.find(o => o.id === orderId);
                if (!order) return;

                // Add to recall bar
                bumpedOrders.unshift(order);
                if (bumpedOrders.length > 5) bumpedOrders.pop();

                document.getElementById('recall-list').innerHTML = bumpedOrders.map(o => `
                    <div class="recall-item" onclick="recallOrder(${o.id})" title="Recall #${o.orderNumber}">
                        <span class="recall-num">${o.orderNumber}</span>
                        <span>${o.tableNumber ? 'T-' + o.tableNumber : 'Takeout'}</span>
                    </div>`).join('');

                // Animate card out locally only
                const card = document.getElementById(`card-${orderId}`);
                if (card) {
                    card.style.transition = 'opacity 0.2s, transform 0.2s';
                    card.style.opacity    = '0';
                    card.style.transform  = 'scale(0.95)';
                    setTimeout(() => {
                        currentOrders = currentOrders.filter(o => o.id !== orderId);
                        renderAll(currentOrders);
                    }, 200);
                } else {
                    currentOrders = currentOrders.filter(o => o.id !== orderId);
                    renderAll(currentOrders);
                }
            }

            // ── RECALL ORDER ──────────────────────────────────────────────────────────
            function recallOrder(orderId) {
                const order = bumpedOrders.find(o => o.id === orderId);
                if (!order) return;
                bumpedOrders = bumpedOrders.filter(o => o.id !== orderId);
                currentOrders.push(order);
                renderAll(currentOrders);
                document.getElementById('recall-list').innerHTML = bumpedOrders.map(o => `
                    <div class="recall-item" onclick="recallOrder(${o.id})">
                        <span class="recall-num">${o.orderNumber}</span>
                        <span>${o.tableNumber ? 'T-' + o.tableNumber : 'Takeout'}</span>
                    </div>`).join('');
            }

            // ── ITEM CHECKBOX ─────────────────────────────────────────────────────────
            function toggleItem(orderId, itemIdx, checkbox) {
                if (!checkedItems[orderId]) checkedItems[orderId] = new Set();
                if (checkbox.checked) checkedItems[orderId].add(itemIdx);
                else checkedItems[orderId].delete(itemIdx);

                const row = document.getElementById(`item-${orderId}-${itemIdx}`);
                if (row) row.classList.toggle('done', checkbox.checked);
            }

            // ── INIT ──────────────────────────────────────────────────────────────────
            fetchOrders();
            setInterval(fetchOrders, POLL_INTERVAL);
    </script>
</body>
</html>
